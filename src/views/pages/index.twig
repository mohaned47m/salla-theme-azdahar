{% extends 'layouts.master' %}

{% block title %}{{ store.name }} - {{ store.description | default('معدات الصيد والرحلات الاحترافية') }}{% endblock %}

{% block content %}

{# ============================================================ #}
{# HERO SECTION - قسم البطل #}
{# ============================================================ #}
<section class="p-4 md:p-10 lg:px-40">
    <div class="relative min-h-[580px] rounded-3xl overflow-hidden flex flex-col justify-center p-8 md:p-20 group">
        <div class="absolute inset-0 bg-cover bg-center transition-transform duration-1000 group-hover:scale-105"
             style="background-image: linear-gradient(270deg, rgba(47, 40, 36, 0.9) 0%, rgba(47, 40, 36, 0.4) 60%, rgba(47, 40, 36, 0) 100%), url('{{ theme.settings.hero_image | default('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1600') }}');">
        </div>
        <div class="relative z-10 max-w-xl">
            <div class="flex items-center gap-2 mb-6">
                <span class="w-10 h-[2px]" style="background-color: var(--brand-secondary);"></span>
                <span class="text-sm font-black tracking-widest uppercase" style="color: var(--brand-secondary);">
                    {{ theme.settings.hero_subtitle | default('رواد معدات الصيد') }}
                </span>
            </div>
            <h2 class="text-5xl md:text-7xl font-black text-white leading-[1.2] mb-8">
                {{ theme.settings.hero_title | default('رفيقك الأمثل في كل') }}
                <span style="color: var(--brand-secondary);">{{ theme.settings.hero_highlight | default('مغامرة') }}</span>
            </h2>
            <p class="text-slate-200 text-lg mb-10 leading-relaxed font-medium">
                {{ theme.settings.hero_description | default('نعيد تعريف التميز في الصيد والرحلات البرية. اختبر الصحراء بمعدات فاخرة تم اختيارها بعناية من قبل خبراء.') }}
            </p>
            <div class="flex flex-wrap gap-5">
                <a href="{{ store.urls.products }}" class="px-10 py-5 text-white font-black rounded-xl hover:shadow-lg transition-all flex items-center gap-3 transform hover:-translate-y-1" style="background-color: var(--brand-secondary);">
                    {{ 'تسوق الأكثر مبيعاً' | trans }}
                    <span class="material-symbols-outlined font-bold">arrow_back</span>
                </a>
                <a href="{{ store.urls.new_arrivals ?? store.urls.products }}" class="px-10 py-5 bg-white font-black rounded-xl border-2 border-transparent hover:border-brand-secondary transition-all transform hover:-translate-y-1" style="color: var(--brand-dark);">
                    {{ 'وصلنا حديثاً' | trans }}
                </a>
            </div>
        </div>
    </div>
</section>

{# ============================================================ #}
{# FEATURES SECTION - مميزات المتجر #}
{# ============================================================ #}
<section class="px-4 md:px-10 lg:px-40 py-12">
    <div class="bg-slate-50 border border-slate-100 rounded-2xl p-10">
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8">
            <div class="flex flex-row items-center gap-4">
                <span class="material-symbols-outlined text-5xl" style="color: var(--brand-secondary);">history_edu</span>
                <div class="text-right">
                    <h4 class="font-bold text-lg" style="color: var(--brand-dark);">{{ 'خبرة ١٠ سنوات' | trans }}</h4>
                    <p class="text-sm text-slate-500">{{ 'رواد في المجال منذ عام ٢٠١٤' | trans }}</p>
                </div>
            </div>
            <div class="flex flex-row items-center gap-4">
                <span class="material-symbols-outlined text-5xl" style="color: var(--brand-secondary);">local_shipping</span>
                <div class="text-right">
                    <h4 class="font-bold text-lg" style="color: var(--brand-dark);">{{ 'شحن سريع' | trans }}</h4>
                    <p class="text-sm text-slate-500">{{ 'توصيل موثوق لجميع المناطق' | trans }}</p>
                </div>
            </div>
            <div class="flex flex-row items-center gap-4">
                <span class="material-symbols-outlined text-5xl" style="color: var(--brand-secondary);">verified</span>
                <div class="text-right">
                    <h4 class="font-bold text-lg" style="color: var(--brand-dark);">{{ 'منتجات أصلية' | trans }}</h4>
                    <p class="text-sm text-slate-500">{{ 'علامات تجارية موثوقة ومجربة' | trans }}</p>
                </div>
            </div>
            <div class="flex flex-row items-center gap-4">
                <span class="material-symbols-outlined text-5xl" style="color: var(--brand-secondary);">support_agent</span>
                <div class="text-right">
                    <h4 class="font-bold text-lg" style="color: var(--brand-dark);">{{ 'دعم فني متخصص' | trans }}</h4>
                    <p class="text-sm text-slate-500">{{ 'متواجدون دائماً لمساعدتك' | trans }}</p>
                </div>
            </div>
        </div>
    </div>
</section>

{# ============================================================ #}
{# CATEGORIES SECTION - تسوق حسب الفئة #}
{# ============================================================ #}
<section class="px-4 md:px-10 lg:px-40 py-16">
    <div class="flex items-end justify-between mb-12">
        <div>
            <h3 class="text-3xl font-black mb-2" style="color: var(--brand-dark);">{{ 'تسوق حسب الفئة' | trans }}</h3>
            <p class="text-slate-500 font-medium">{{ 'معدات احترافية مصممة لاحتياجاتك الخاصة' | trans }}</p>
        </div>
        <a href="{{ store.urls.categories ?? '#' }}" class="font-bold text-sm flex items-center gap-2 group" style="color: var(--brand-secondary);">
            {{ 'عرض الكل' | trans }}
            <span class="material-symbols-outlined text-sm transition-transform group-hover:-translate-x-1">arrow_back</span>
        </a>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {% for category in categories | slice(0, 4) %}
            <a href="{{ category.url }}" class="group relative aspect-[4/5] overflow-hidden rounded-2xl cursor-pointer block">
                <div class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-110"
                     style="background-image: linear-gradient(0deg, rgba(47, 40, 36, 0.8) 0%, rgba(47, 40, 36, 0.1) 100%), url('{{ category.image }}');">
                </div>
                <div class="absolute bottom-6 right-6 left-6">
                    <h4 class="text-xl font-black text-white mb-1">{{ category.name }}</h4>
                    <span class="text-xs font-bold bg-white/10 backdrop-blur-md px-2 py-1 rounded" style="color: var(--brand-secondary);">
                        {{ category.products_count }}+ {{ 'منتج' | trans }}
                    </span>
                </div>
            </a>
        {% endfor %}
    </div>
</section>

{# ============================================================ #}
{# BANNER 1 - بانر الفئة المميزة #}
{# ============================================================ #}
<section class="px-4 md:px-10 lg:px-40 pb-8" style="background-color: #fcf9f6;">
    <div class="relative h-[280px] rounded-2xl overflow-hidden group">
        <div class="absolute inset-0 bg-cover bg-center transition-transform duration-1000 group-hover:scale-105"
             style="background-image: linear-gradient(270deg, rgba(47, 40, 36, 0.7) 0%, rgba(47, 40, 36, 0.2) 100%), url('{{ theme.settings.banner1_image | default('https://images.unsplash.com/photo-1551698618-1dfe5d97d256?w=1200') }}');">
        </div>
        <div class="relative z-10 h-full flex flex-col justify-center px-12 max-w-2xl">
            <span class="text-xs font-black tracking-[0.2em] uppercase mb-3" style="color: var(--brand-secondary);">
                {{ theme.settings.banner1_subtitle | default('درجة احترافية') }}
            </span>
            <h3 class="text-3xl md:text-4xl font-black text-white mb-6 leading-tight">
                {{ theme.settings.banner1_title | default('مجموعة البصريات الفاخرة') }}
            </h3>
            <a href="{{ theme.settings.banner1_url | default(store.urls.products) }}" class="w-fit px-8 py-3.5 text-white font-black rounded-lg hover:brightness-110 transition-all shadow-lg flex items-center gap-2" style="background-color: var(--brand-secondary);">
                {{ 'تسوق الآن' | trans }}
                <span class="material-symbols-outlined text-sm">arrow_back</span>
            </a>
        </div>
    </div>
</section>

{# ============================================================ #}
{# FLASH SALES - عروض الفلاش #}
{# ============================================================ #}
<section class="px-4 md:px-10 lg:px-40 py-16" style="background-color: #fcf9f6;">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-8 mb-12">
        <div class="flex items-center gap-5">
            <div class="size-14 rounded-2xl flex items-center justify-center text-white shadow-xl" style="background-color: var(--brand-secondary);">
                <span class="material-symbols-outlined text-3xl">bolt</span>
            </div>
            <div>
                <h3 class="text-3xl font-black" style="color: var(--brand-dark);">{{ 'عروض الفلاش الحصرية' | trans }}</h3>
                <p class="text-slate-500 font-medium">{{ 'معدات فاخرة بأسعار استثنائية' | trans }}</p>
            </div>
        </div>
        <div class="flex items-center gap-4 bg-white p-4 rounded-2xl brand-shadow">
            <span class="text-xs font-black tracking-widest uppercase" style="color: var(--brand-dark);">{{ 'ينتهي خلال:' | trans }}</span>
            <div class="flex gap-2" dir="ltr">
                <div class="flex flex-col items-center">
                    <div class="text-white w-10 h-10 rounded flex items-center justify-center font-black" style="background-color: var(--brand-dark);" id="flash-hours">12</div>
                    <span class="text-[8px] mt-1 font-bold text-slate-400">{{ 'ساعة' | trans }}</span>
                </div>
                <span class="pt-2 font-black" style="color: var(--brand-dark);">:</span>
                <div class="flex flex-col items-center">
                    <div class="text-white w-10 h-10 rounded flex items-center justify-center font-black" style="background-color: var(--brand-dark);" id="flash-minutes">45</div>
                    <span class="text-[8px] mt-1 font-bold text-slate-400">{{ 'دقيقة' | trans }}</span>
                </div>
                <span class="pt-2 font-black" style="color: var(--brand-dark);">:</span>
                <div class="flex flex-col items-center">
                    <div class="text-white w-10 h-10 rounded flex items-center justify-center font-black" style="background-color: var(--brand-dark);" id="flash-seconds">08</div>
                    <span class="text-[8px] mt-1 font-bold text-slate-400">{{ 'ثانية' | trans }}</span>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {% for product in products | slice(0, 4) %}
            <div class="bg-white rounded-2xl p-4 brand-shadow border border-slate-50 group transition-all hover:border-brand-secondary/30">
                <div class="relative aspect-square rounded-xl overflow-hidden bg-slate-100 mb-5">
                    <a href="{{ product.url }}">
                        <img alt="{{ product.name }}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" src="{{ product.thumbnail }}"/>
                    </a>
                    {% if product.discount_percent %}
                        <span class="absolute top-3 right-3 text-white text-[10px] font-black px-3 py-1.5 rounded-full uppercase tracking-wider shadow-lg" style="background-color: var(--brand-secondary);">
                            {{ 'وفر' | trans }} {{ product.discount_percent }}٪
                        </span>
                    {% endif %}
                </div>
                <h5 class="font-black mb-1 text-lg leading-tight truncate" style="color: var(--brand-dark);">{{ product.name }}</h5>
                <div class="flex items-center gap-1 mb-4">
                    <div class="flex items-center gap-0.5">
                        {% for i in 1..5 %}
                            <span class="material-symbols-outlined text-[16px]" style="color: var(--brand-secondary); font-variation-settings: 'FILL' 1">star</span>
                        {% endfor %}
                    </div>
                    <span class="text-[12px] text-slate-400 font-bold mr-1">({{ product.reviews_count | default(0) }} {{ 'تقييم' | trans }})</span>
                </div>
                <div class="flex items-baseline gap-2 mb-5">
                    <span class="font-black text-2xl" style="color: var(--brand-secondary);">{{ product.price | price }}</span>
                    {% if product.sale_price %}
                        <span class="text-slate-400 line-through text-sm font-medium">{{ product.sale_price | price }}</span>
                    {% endif %}
                </div>
                <div class="mb-5 space-y-2">
                    <div class="flex justify-between text-[11px] font-black uppercase text-slate-500">
                        <span>{{ 'تم بيع:' | trans }} {{ product.sold_quantity | default(0) }}</span>
                        {% if product.quantity and product.quantity < 10 %}
                            <span class="text-red-600">{{ 'بقي' | trans }} {{ product.quantity }} {{ 'فقط' | trans }}</span>
                        {% endif %}
                    </div>
                    <div class="w-full h-2 bg-slate-100 rounded-full overflow-hidden">
                        <div class="h-full rounded-full" style="width: 70%; background-color: var(--brand-secondary);"></div>
                    </div>
                </div>
                <salla-add-product-button product-id="{{ product.id }}" product-status="{{ product.status }}">
                    <button class="w-full py-4 text-white font-black rounded-xl hover:brightness-110 transition-all flex items-center justify-center gap-2 group/btn" style="background-color: var(--brand-dark);">
                        <span class="material-symbols-outlined text-xl transition-transform group-hover/btn:scale-110">shopping_cart</span>
                        {{ 'أضف للسلة' | trans }}
                    </button>
                </salla-add-product-button>
            </div>
        {% endfor %}
    </div>
</section>

{# ============================================================ #}
{# BANNER 2 - بانر ثانوي #}
{# ============================================================ #}
<section class="px-4 md:px-10 lg:px-40 py-8 bg-white">
    <div class="relative h-[240px] rounded-2xl overflow-hidden group">
        <div class="absolute inset-0 bg-cover bg-center transition-transform duration-1000 group-hover:scale-105"
             style="background-image: linear-gradient(270deg, rgba(47, 40, 36, 0.6) 0%, rgba(47, 40, 36, 0.1) 100%), url('{{ theme.settings.banner2_image | default('https://images.unsplash.com/photo-1504280390367-361c6d9f38f4?w=1200') }}');">
        </div>
        <div class="relative z-10 h-full flex flex-col justify-center px-12 max-w-xl">
            <h3 class="text-2xl md:text-3xl font-black text-white mb-4">
                {{ theme.settings.banner2_title | default('حقائب النجاة المجربة ميدانياً') }}
            </h3>
            <p class="text-white/80 text-sm mb-6 leading-relaxed">
                {{ theme.settings.banner2_description | default('موثوقة من قبل مستكشفي الصحراء المحترفين في جميع أنحاء الجزيرة العربية.') }}
            </p>
            <a href="{{ theme.settings.banner2_url | default(store.urls.products) }}" class="w-fit px-6 py-3 text-white font-bold rounded-lg hover:brightness-110 transition-all flex items-center gap-2" style="background-color: var(--brand-secondary);">
                {{ 'استكشف معدات النجاة' | trans }}
                <span class="material-symbols-outlined text-sm">arrow_back</span>
            </a>
        </div>
    </div>
</section>

{# ============================================================ #}
{# TESTIMONIALS - تجارب المجتمع #}
{# ============================================================ #}
<section class="px-4 md:px-10 lg:px-40 py-20 bg-white">
    <div class="flex items-center justify-between mb-12">
        <div>
            <h3 class="text-3xl font-black mb-2" style="color: var(--brand-dark);">{{ 'تجارب المجتمع' | trans }}</h3>
            <p class="text-slate-500 font-medium">{{ 'انضم لآلاف الراضين في جميع أنحاء المملكة' | trans }}</p>
        </div>
        <div class="hidden md:flex gap-3">
            <button onclick="scrollTestimonials(-1)" class="size-12 rounded-full border border-slate-200 flex items-center justify-center transition-all" style="color: var(--brand-dark);">
                <span class="material-symbols-outlined">chevron_right</span>
            </button>
            <button onclick="scrollTestimonials(1)" class="size-12 rounded-full border border-slate-200 flex items-center justify-center transition-all" style="color: var(--brand-dark);">
                <span class="material-symbols-outlined">chevron_left</span>
            </button>
        </div>
    </div>
    <div id="testimonials-container" class="flex overflow-x-auto no-scrollbar gap-6 pb-4">
        {% set testimonials = [
            {name: 'فيصل العتيبي', location: 'الرياض', text: 'جودة معدات الصيد التي اشتريتها لا تضاهى. يمكنك حقاً ملاحظة الخبرة الطويلة في اختيار أفضل القطع. الشحن كان سريعاً جداً!'},
            {name: 'محمد الشمري', location: 'جدة', text: 'أستخدم حقائب التخييم الخاصة بهم منذ موسمين. كل شيء مصمم بجودة احترافية. فريق الدعم ساعدني في اختيار البصريات المناسبة.'},
            {name: 'عبدالله القحطاني', location: 'الدمام', text: 'تجربة تسوق رائعة! المنتجات أصلية 100% والتوصيل في الموعد المحدد. سأكون عميلاً دائماً لهذا المتجر المتميز.'}
        ] %}
        {% for t in testimonials %}
            <div class="min-w-[320px] md:min-w-[400px] bg-white p-8 rounded-2xl border border-slate-100 brand-shadow flex flex-col justify-between">
                <div>
                    <div class="flex gap-1 mb-6">
                        {% for i in 1..5 %}
                            <span class="material-symbols-outlined" style="color: var(--brand-secondary); font-variation-settings: 'FILL' 1">star</span>
                        {% endfor %}
                    </div>
                    <p class="font-medium leading-relaxed italic mb-8" style="color: var(--brand-dark);">"{{ t.text }}"</p>
                </div>
                <div class="flex items-center justify-between">
                    <div>
                        <h5 class="font-black" style="color: var(--brand-dark);">{{ t.name }}</h5>
                        <p class="text-[10px] text-slate-400 font-bold tracking-widest uppercase mt-1">{{ t.location }}، المملكة العربية السعودية</p>
                    </div>
                    <div class="flex items-center gap-1.5 px-3 py-1.5 bg-slate-50 rounded-full border border-slate-100">
                        <span class="material-symbols-outlined text-[16px] text-green-600" style="font-variation-settings: 'FILL' 1">verified_user</span>
                        <span class="text-[10px] font-black text-slate-600 uppercase">{{ 'مشتري موثق' | trans }}</span>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
</section>

{# ============================================================ #}
{# FEATURED PRODUCTS - المنتجات المختارة #}
{# ============================================================ #}
<section class="px-4 md:px-10 lg:px-40 py-16 bg-white">
    <div class="flex items-end justify-between mb-12">
        <div>
            <h3 class="text-3xl font-black mb-2" style="color: var(--brand-dark);">{{ 'اكتشف مجموعتنا المختارة' | trans }}</h3>
            <p class="text-slate-500 font-medium">{{ 'أفضل المنتجات المختارة بعناية لضمان أداء استثنائي' | trans }}</p>
        </div>
        <a href="{{ store.urls.products }}" class="font-bold text-sm flex items-center gap-2 group" style="color: var(--brand-secondary);">
            {{ 'عرض الكل' | trans }}
            <span class="material-symbols-outlined text-sm transition-transform group-hover:-translate-x-1">arrow_back</span>
        </a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {% for product in products | slice(4, 8) %}
            <div class="bg-white rounded-2xl p-4 border border-slate-100 transition-all duration-300 hover:shadow-xl group">
                <div class="relative aspect-square rounded-xl overflow-hidden bg-slate-50 mb-4">
                    <a href="{{ product.url }}">
                        <img alt="{{ product.name }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="{{ product.thumbnail }}"/>
                    </a>
                </div>
                <a href="{{ product.url }}">
                    <h4 class="font-bold text-lg mb-2 truncate" style="color: var(--brand-dark);">{{ product.name }}</h4>
                </a>
                <div class="flex items-center gap-0.5 mb-3">
                    {% for i in 1..5 %}
                        <span class="material-symbols-outlined text-[16px]" style="color: var(--brand-secondary); font-variation-settings: 'FILL' 1">star</span>
                    {% endfor %}
                </div>
                <div class="font-black text-xl mb-5" style="color: var(--brand-dark);">{{ product.price | price }}</div>
                <salla-add-product-button product-id="{{ product.id }}" product-status="{{ product.status }}">
                    <button class="w-full py-3.5 text-white font-bold rounded-xl hover:brightness-110 transition-colors flex items-center justify-center gap-2" style="background-color: var(--brand-dark);">
                        <span class="material-symbols-outlined text-xl">shopping_cart</span>
                        {{ 'أضف للسلة' | trans }}
                    </button>
                </salla-add-product-button>
            </div>
        {% endfor %}
    </div>
</section>

{# ============================================================ #}
{# FAQ SECTION - الأسئلة الشائعة #}
{# ============================================================ #}
<section class="px-4 md:px-10 lg:px-40 py-20 bg-white border-t border-slate-50">
    <div class="max-w-3xl mx-auto">
        <div class="text-center mb-16">
            <h3 class="text-3xl font-black mb-4" style="color: var(--brand-dark);">{{ 'الأسئلة الشائعة' | trans }}</h3>
            <p class="text-slate-500 font-medium">{{ 'كل ما تحتاج معرفته عن معداتنا وخدماتنا الاحترافية.' | trans }}</p>
        </div>
        <div class="space-y-4">
            {% set faqs = [
                {q: 'هل تتوفر ضمانات على المنتجات؟', a: 'نعم، جميع معدات الصيد الاحترافية لدينا تأتي مع ضمان قياسي لمدة سنتين يغطي عيوب التصنيع.'},
                {q: 'كم يستغرق الشحن داخل المملكة العربية السعودية؟', a: 'بالنسبة للمدن الكبرى مثل الرياض وجدة والدمام، يستغرق التوصيل عادةً من ٢٤ إلى ٤٨ ساعة.'},
                {q: 'هل المنتجات أصلية ١٠٠٪؟', a: 'بكل تأكيد. نحن نستورد المنتجات مباشرة من المصنعين المعتمدين. كل قطعة أصلية ١٠٠٪ ومجربة ميدانياً.'}
            ] %}
            {% for faq in faqs %}
                <details class="group bg-slate-50 rounded-2xl overflow-hidden transition-all duration-300">
                    <summary class="flex items-center justify-between p-6 cursor-pointer list-none text-right">
                        <span class="text-lg font-bold" style="color: var(--brand-dark);">{{ faq.q }}</span>
                        <span class="material-symbols-outlined transition-transform duration-300 expand-icon" style="color: var(--brand-secondary);">expand_more</span>
                    </summary>
                    <div class="px-6 pb-6 text-slate-600 leading-relaxed text-right">{{ faq.a }}</div>
                </details>
            {% endfor %}
        </div>
        <div class="mt-12 p-6 rounded-2xl border flex flex-col md:flex-row items-center justify-between gap-6" style="background-color: rgba(135, 96, 44, 0.05); border-color: rgba(135, 96, 44, 0.1);">
            <div class="text-right">
                <h5 class="font-bold" style="color: var(--brand-dark);">{{ 'لا تزال لديك أسئلة؟' | trans }}</h5>
                <p class="text-sm text-slate-500">{{ 'خبراؤنا متاحون على مدار الساعة لمساعدتك.' | trans }}</p>
            </div>
            <a href="{{ store.urls.contact ?? '#' }}" class="px-6 py-3 text-white text-sm font-bold rounded-xl hover:brightness-110 transition-all" style="background-color: var(--brand-dark);">
                {{ 'تواصل مع الدعم' | trans }}
            </a>
        </div>
    </div>
</section>

{% endblock %}

{% block extra_footer %}
<script>
// Flash Sales Countdown Timer
(function() {
    var endTime = new Date();
    endTime.setHours(endTime.getHours() + 12);
    endTime.setMinutes(endTime.getMinutes() + 45);
    endTime.setSeconds(endTime.getSeconds() + 8);

    function pad(n) { return String(n).padStart(2, '0'); }

    function updateCountdown() {
        var now = new Date();
        var diff = endTime - now;
        if (diff <= 0) return;
        var h = document.getElementById('flash-hours');
        var m = document.getElementById('flash-minutes');
        var s = document.getElementById('flash-seconds');
        if (h) h.textContent = pad(Math.floor(diff / 3600000));
        if (m) m.textContent = pad(Math.floor((diff % 3600000) / 60000));
        if (s) s.textContent = pad(Math.floor((diff % 60000) / 1000));
    }
    updateCountdown();
    setInterval(updateCountdown, 1000);
})();

// Testimonials Scroll
function scrollTestimonials(dir) {
    var c = document.getElementById('testimonials-container');
    if (c) c.scrollBy({ left: dir * 420, behavior: 'smooth' });
}

// FAQ Accordion
document.querySelectorAll('details').forEach(function(d) {
    d.addEventListener('toggle', function() {
        var icon = this.querySelector('.expand-icon');
        if (icon) icon.style.transform = this.open ? 'rotate(180deg)' : '';
    });
});
</script>
{% endblock %}
