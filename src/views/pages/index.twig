{% block scripts %}
<script defer src="{{ 'home.js' | asset }}"></script>
<script>
(function() {
  /* ---- Scroll Reveal ---- */
  var reveals = document.querySelectorAll('.az-reveal');
  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) {
          e.target.classList.add('az-visible');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.12 });
    reveals.forEach(function(el) { io.observe(el); });
  } else {
    reveals.forEach(function(el) { el.classList.add('az-visible'); });
  }

  /* ---- Countdown Timer ---- */
  var end = new Date();
  end.setHours(end.getHours() + 12, end.getMinutes() + 45, end.getSeconds() + 8);

  function pad(n) { return String(n).padStart(2, '0'); }

  function flipNum(el, val) {
    var current = el.textContent;
    if (current === val) return;
    el.classList.add('az-flip');
    setTimeout(function() {
      el.textContent = val;
      el.classList.remove('az-flip');
    }, 150);
  }

  function tick() {
    var diff = end - new Date();
    if (diff <= 0) return;
    var h = document.getElementById('az-hours');
    var m = document.getElementById('az-minutes');
    var s = document.getElementById('az-seconds');
    if (h) flipNum(h, pad(Math.floor(diff / 3600000)));
    if (m) flipNum(m, pad(Math.floor((diff % 3600000) / 60000)));
    if (s) flipNum(s, pad(Math.floor((diff % 60000) / 1000)));
  }
  tick();
  setInterval(tick, 1000);

  /* ---- Coupon Copy ---- */
  var coupon = document.querySelector('.az-promo__coupon');
  if (coupon) {
    coupon.style.cursor = 'pointer';
    coupon.addEventListener('click', function() {
      var code = coupon.querySelector('.az-promo__coupon-code');
      if (!code) return;
      navigator.clipboard && navigator.clipboard.writeText(code.textContent.trim());
      var icon = coupon.querySelector('.material-symbols-outlined');
      if (icon) {
        icon.textContent = 'check_circle';
        setTimeout(function() { icon.textContent = 'content_copy'; }, 2000);
      }
    });
  }

  /* ---- Hero BG slow zoom on load ---- */
  var heroBg = document.querySelector('.az-hero__bg');
  if (heroBg) {
    setTimeout(function() { heroBg.style.transform = 'scale(1)'; }, 100);
  }

})();
</script>
{% endblock %}
