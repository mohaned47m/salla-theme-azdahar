{% extends "layouts.master" %}

{% block styles %}
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet">
<style>
/* ============================================================
   ثيم ازدهار — الصفحة الرئيسية — نسخة CRO محسّنة
   ============================================================ */

/* ── متغيرات ── */
:root {
  --az-primary:      #2563eb;
  --az-primary-dk:   #1d4ed8;
  --az-primary-lt:   #eff6ff;
  --az-accent:       #f59e0b;
  --az-accent-dk:    #d97706;
  --az-success:      #10b981;
  --az-danger:       #ef4444;
  --az-text:         #1e293b;
  --az-muted:        #64748b;
  --az-border:       #e2e8f0;
  --az-bg:           #f8fafc;
  --az-white:        #ffffff;
  --az-r:            12px;
  --az-r-lg:         20px;
  --az-shadow:       0 4px 24px rgba(0,0,0,.08);
  --az-shadow-hv:    0 8px 40px rgba(0,0,0,.14);
  --az-tr:           all .3s cubic-bezier(.4,0,.2,1);
  --az-py:           80px;
}

/* ── ريست ── */
.az-page *, .az-page *::before, .az-page *::after { box-sizing: border-box; }
.az-page { font-family: 'Tajawal', sans-serif; color: var(--az-text); background: var(--az-bg); overflow-x: hidden; }
.az-page a { text-decoration: none; color: inherit; }
.az-page img { display: block; max-width: 100%; }

/* ── تسمية الأقسام ── */
.az-label {
  display: flex; align-items: center; justify-content: center; gap: 10px;
  padding: 10px 0; font-size: .68rem; font-weight: 700;
  letter-spacing: .14em; text-transform: uppercase;
  color: var(--az-muted); opacity: .45;
  user-select: none; pointer-events: none;
}
.az-label::before, .az-label::after {
  content: ''; flex: 1; max-width: 80px; height: 1px; background: var(--az-border);
}

/* ── Scroll Reveal ── */
.az-r { opacity: 0; transform: translateY(28px); transition: opacity .65s ease, transform .65s ease; }
.az-r.on { opacity: 1; transform: none; }
.az-r.d1 { transition-delay: .1s; } .az-r.d2 { transition-delay: .2s; }
.az-r.d3 { transition-delay: .3s; } .az-r.d4 { transition-delay: .4s; }

/* ── Container & Section ── */
.az-con { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
.az-sec { padding: var(--az-py) 0; }
.az-sec--white { background: var(--az-white); }
.az-sec--gray  { background: var(--az-bg); }
.az-sec--dark  { background: #0f172a; }

/* ── Section Head ── */
.az-head { text-align: center; margin-bottom: 48px; }
.az-eyebrow {
  display: inline-flex; align-items: center; gap: 8px;
  font-size: .78rem; font-weight: 800; letter-spacing: .12em;
  text-transform: uppercase; color: var(--az-primary); margin-bottom: 12px;
}
.az-eyebrow::before, .az-eyebrow::after { content: ''; width: 24px; height: 2px; background: currentColor; border-radius: 2px; }
.az-h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 900; color: var(--az-text); margin: 0 0 12px; line-height: 1.3; }
.az-sub { font-size: .97rem; color: var(--az-muted); max-width: 520px; margin: 0 auto; line-height: 1.7; }

/* ── Buttons ── */
.az-btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 13px 28px; border-radius: 50px; font-size: .95rem;
  font-weight: 700; font-family: inherit; cursor: pointer;
  border: 2px solid transparent; transition: var(--az-tr); white-space: nowrap;
}
.az-btn .ms { font-size: 1.1rem; }
.az-btn--blue   { background: var(--az-primary); color: #fff; border-color: var(--az-primary); }
.az-btn--blue:hover   { background: var(--az-primary-dk); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(37,99,235,.35); }
.az-btn--amber  { background: var(--az-accent); color: #fff; border-color: var(--az-accent); }
.az-btn--amber:hover  { background: var(--az-accent-dk); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(245,158,11,.35); }
.az-btn--ghost  { background: transparent; color: var(--az-primary); border-color: var(--az-primary); }
.az-btn--ghost:hover  { background: var(--az-primary); color: #fff; transform: translateY(-2px); }
.az-btn--white  { background: #fff; color: var(--az-primary); }
.az-btn--white:hover  { background: var(--az-primary-lt); transform: translateY(-2px); }
.az-btn--wghost { background: transparent; color: #fff; border-color: rgba(255,255,255,.5); }
.az-btn--wghost:hover { background: rgba(255,255,255,.1); transform: translateY(-2px); }

/* ============================================================
   1. ANNOUNCEMENT BAR
   ============================================================ */
.az-topbar {
  background: var(--az-primary); color: #fff;
  padding: 10px 24px; text-align: center;
  font-size: .87rem; font-weight: 600; position: relative;
}
.az-topbar__inner { display: flex; align-items: center; justify-content: center; gap: 10px; }
.az-topbar__badge { background: var(--az-accent); padding: 2px 10px; border-radius: 50px; font-size: .72rem; font-weight: 800; }
.az-topbar a { color: #fff; text-decoration: underline; opacity: .85; }
.az-topbar a:hover { opacity: 1; }
.az-topbar__x { position: absolute; left: 16px; top: 50%; transform: translateY(-50%); background: none; border: none; color: rgba(255,255,255,.7); cursor: pointer; display: flex; align-items: center; }
.az-topbar__x:hover { color: #fff; }

/* ============================================================
   2. HERO
   ============================================================ */
.az-hero {
  position: relative; min-height: 90vh;
  display: flex; align-items: center; overflow: hidden;
  background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 60%, #0f172a 100%);
}
.az-hero__bg {
  position: absolute; inset: 0;
  background: url('https://images.unsplash.com/photo-1441986300917-64674bd600d8?w=1600&q=80') center/cover;
  opacity: .22; transform: scale(1.08); transition: transform 9s ease;
}
.az-hero__bg.loaded { transform: scale(1); }
.az-hero__ov { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(15,23,42,.88) 0%, rgba(30,58,95,.55) 100%); }
.az-hero__con { position: relative; z-index: 2; max-width: 640px; }
.az-hero__badge {
  display: inline-flex; align-items: center; gap: 6px;
  background: rgba(245,158,11,.15); border: 1px solid rgba(245,158,11,.4);
  color: var(--az-accent); padding: 6px 16px; border-radius: 50px;
  font-size: .82rem; font-weight: 700; margin-bottom: 24px;
  animation: pulse-badge 3s ease infinite;
}
@keyframes pulse-badge { 0%,100%{box-shadow:0 0 0 0 rgba(245,158,11,.3)} 50%{box-shadow:0 0 0 8px rgba(245,158,11,0)} }
.az-hero__h1 {
  font-size: clamp(2.2rem, 5vw, 3.8rem); font-weight: 900; color: #fff;
  line-height: 1.15; margin: 0 0 20px;
  animation: slideup .8s ease both;
}
.az-hero__h1 span { color: var(--az-accent); }
.az-hero__p {
  font-size: 1.08rem; color: rgba(255,255,255,.75); line-height: 1.75;
  margin: 0 0 36px; animation: slideup .8s .15s ease both;
}
.az-hero__btns { display: flex; gap: 14px; flex-wrap: wrap; animation: slideup .8s .3s ease both; }
.az-hero__stats {
  display: flex; gap: 32px; margin-top: 48px;
  padding-top: 32px; border-top: 1px solid rgba(255,255,255,.12);
  animation: slideup .8s .45s ease both;
}
.az-hero__stat-n { font-size: 1.9rem; font-weight: 900; color: #fff; line-height: 1; }
.az-hero__stat-l { font-size: .76rem; color: rgba(255,255,255,.5); margin-top: 4px; }
.az-hero__div { width: 1px; background: rgba(255,255,255,.15); }
.az-hero__scroll {
  position: absolute; bottom: 28px; left: 50%; transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 6px;
  color: rgba(255,255,255,.35); font-size: .7rem; letter-spacing: .08em;
  animation: bounce 2s ease infinite;
}
.az-hero__scroll-dot { width: 5px; height: 5px; background: rgba(255,255,255,.35); border-radius: 50%; }
@keyframes slideup { from{opacity:0;transform:translateY(30px)} to{opacity:1;transform:none} }
@keyframes bounce   { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(8px)} }

/* ============================================================
   3. TRUST BAR
   ============================================================ */
.az-trust { background: #fff; border-bottom: 1px solid var(--az-border); }
.az-trust__grid { display: grid; grid-template-columns: repeat(4, 1fr); }
.az-trust__item {
  display: flex; align-items: center; gap: 14px;
  padding: 24px 20px; border-left: 1px solid var(--az-border);
  transition: var(--az-tr);
}
.az-trust__item:last-child { border-left: none; }
.az-trust__item:hover { background: var(--az-primary-lt); }
.az-trust__icon {
  width: 44px; height: 44px; border-radius: 10px;
  background: var(--az-primary-lt); color: var(--az-primary);
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  transition: var(--az-tr);
}
.az-trust__item:hover .az-trust__icon { background: var(--az-primary); color: #fff; }
.az-trust__t strong { display: block; font-size: .9rem; font-weight: 700; }
.az-trust__t span   { font-size: .77rem; color: var(--az-muted); }

/* ============================================================
   4. CATEGORIES
   ============================================================ */
.az-cats__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
.az-cat {
  position: relative; border-radius: var(--az-r-lg);
  overflow: hidden; aspect-ratio: 3/4;
  box-shadow: var(--az-shadow); cursor: pointer; display: block;
  transition: var(--az-tr);
}
.az-cat:hover { transform: translateY(-6px); box-shadow: var(--az-shadow-hv); }
.az-cat__img { width: 100%; height: 100%; object-fit: cover; transition: transform .6s ease; }
.az-cat:hover .az-cat__img { transform: scale(1.07); }
.az-cat__ov {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,.78) 0%, rgba(0,0,0,.08) 60%, transparent 100%);
  transition: var(--az-tr);
}
.az-cat:hover .az-cat__ov { background: linear-gradient(to top, rgba(0,0,0,.88) 0%, rgba(0,0,0,.2) 60%, transparent 100%); }
.az-cat__body { position: absolute; bottom: 0; left: 0; right: 0; padding: 22px 18px; }
.az-cat__name { font-size: 1.08rem; font-weight: 800; color: #fff; margin: 0 0 5px; }
.az-cat__count { font-size: .78rem; color: rgba(255,255,255,.6); }
.az-cat__cta {
  display: inline-flex; align-items: center; gap: 4px;
  background: #fff; color: var(--az-primary);
  padding: 6px 14px; border-radius: 50px; font-size: .78rem; font-weight: 700;
  margin-top: 10px; opacity: 0; transform: translateY(8px); transition: var(--az-tr);
}
.az-cat:hover .az-cat__cta { opacity: 1; transform: none; }
.az-cat--wide { grid-column: span 2; aspect-ratio: 16/9; }

/* ============================================================
   5. FEATURED PRODUCTS
   ============================================================ */
.az-prods__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
.az-prod {
  background: #fff; border-radius: var(--az-r);
  border: 1px solid var(--az-border); overflow: hidden;
  transition: var(--az-tr); position: relative;
}
.az-prod:hover { transform: translateY(-4px); box-shadow: var(--az-shadow-hv); border-color: transparent; }
.az-prod__img-w { position: relative; aspect-ratio: 1; overflow: hidden; background: var(--az-bg); }
.az-prod__img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s ease; }
.az-prod:hover .az-prod__img { transform: scale(1.06); }
.az-prod__badge {
  position: absolute; top: 12px; right: 12px;
  background: var(--az-danger); color: #fff;
  padding: 3px 10px; border-radius: 50px; font-size: .7rem; font-weight: 800;
}
.az-prod__badge--new { background: var(--az-success); }
.az-prod__wish {
  position: absolute; top: 12px; left: 12px;
  width: 34px; height: 34px; border-radius: 50%;
  background: #fff; border: none; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 2px 8px rgba(0,0,0,.12); transition: var(--az-tr); opacity: 0;
}
.az-prod:hover .az-prod__wish { opacity: 1; }
.az-prod__wish:hover { background: #fee2e2; color: var(--az-danger); }
.az-prod__body { padding: 16px; }
.az-prod__cat  { font-size: .7rem; color: var(--az-primary); font-weight: 700; text-transform: uppercase; letter-spacing: .06em; margin-bottom: 5px; }
.az-prod__name { font-size: .93rem; font-weight: 700; color: var(--az-text); margin: 0 0 10px; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.az-prod__stars { color: var(--az-accent); font-size: .82rem; margin-bottom: 10px; }
.az-prod__foot { display: flex; align-items: center; justify-content: space-between; }
.az-prod__price { font-size: 1.08rem; font-weight: 800; color: var(--az-primary); }
.az-prod__old   { font-size: .8rem; color: var(--az-muted); text-decoration: line-through; margin-left: 4px; }
.az-prod__add {
  width: 36px; height: 36px; border-radius: 50%;
  background: var(--az-primary); color: #fff;
  border: none; cursor: pointer; display: flex; align-items: center; justify-content: center;
  transition: var(--az-tr);
}
.az-prod__add:hover { background: var(--az-primary-dk); transform: scale(1.1); }

/* ============================================================
   6. FLASH SALES
   ============================================================ */
.az-flash { background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%); }
.az-flash__top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 40px; flex-wrap: wrap; gap: 20px; }
.az-flash__left { display: flex; align-items: center; gap: 14px; }
.az-flash__fire { font-size: 2rem; animation: flicker 1.5s ease infinite; }
@keyframes flicker { 0%,100%{opacity:1} 50%{opacity:.55} }
.az-flash__h2 { font-size: 1.8rem; font-weight: 900; color: #fff; margin: 0; }
.az-flash__sub { font-size: .85rem; color: rgba(255,255,255,.5); margin-top: 4px; }
.az-cd { display: flex; align-items: center; gap: 8px; }
.az-cd__u { text-align: center; }
.az-cd__n {
  display: flex; align-items: center; justify-content: center;
  width: 56px; height: 56px; border-radius: 10px;
  background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.15);
  font-size: 1.6rem; font-weight: 900; color: #fff;
  transition: transform .15s ease;
}
.az-cd__n.flip { transform: scaleY(0); }
.az-cd__l { font-size: .66rem; color: rgba(255,255,255,.4); margin-top: 5px; }
.az-cd__sep { font-size: 1.4rem; font-weight: 900; color: var(--az-accent); margin-bottom: 16px; animation: blink 1s ease infinite; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:.15} }
.az-flash__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
.az-fc {
  background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1);
  border-radius: var(--az-r); overflow: hidden; transition: var(--az-tr);
}
.az-fc:hover { background: rgba(255,255,255,.1); transform: translateY(-4px); }
.az-fc__img-w { position: relative; aspect-ratio: 1; overflow: hidden; background: rgba(255,255,255,.04); }
.az-fc__img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s ease; }
.az-fc:hover .az-fc__img { transform: scale(1.06); }
.az-fc__disc { position: absolute; top: 10px; right: 10px; background: var(--az-danger); color: #fff; padding: 3px 10px; border-radius: 50px; font-size: .7rem; font-weight: 800; }
.az-fc__body { padding: 14px; }
.az-fc__name { font-size: .88rem; font-weight: 700; color: #fff; margin: 0 0 8px; line-height: 1.4; }
.az-fc__bar-w { height: 4px; background: rgba(255,255,255,.1); border-radius: 2px; margin-bottom: 6px; overflow: hidden; }
.az-fc__bar { height: 100%; background: var(--az-accent); border-radius: 2px; width: 0; transition: width 1.5s ease; }
.az-fc__stock { font-size: .7rem; color: rgba(255,255,255,.45); margin-bottom: 10px; }
.az-fc__foot { display: flex; align-items: center; justify-content: space-between; }
.az-fc__price { font-size: 1.02rem; font-weight: 800; color: var(--az-accent); }
.az-fc__old   { font-size: .75rem; color: rgba(255,255,255,.3); text-decoration: line-through; display: block; }
.az-fc__add { background: var(--az-accent); color: #fff; border: none; border-radius: 8px; padding: 7px 14px; font-size: .8rem; font-weight: 700; cursor: pointer; transition: var(--az-tr); font-family: inherit; }
.az-fc__add:hover { background: var(--az-accent-dk); }

/* ============================================================
   7. PROMO BANNER
   ============================================================ */
.az-promo { background: linear-gradient(135deg, var(--az-accent) 0%, #f97316 100%); position: relative; overflow: hidden; }
.az-promo__c { position: absolute; border-radius: 50%; background: rgba(255,255,255,.08); animation: float 6s ease-in-out infinite; }
.az-promo__c:nth-child(1) { width: 320px; height: 320px; top: -110px; right: -90px; }
.az-promo__c:nth-child(2) { width: 200px; height: 200px; bottom: -60px; left: 8%; animation-delay: -2s; }
.az-promo__c:nth-child(3) { width: 140px; height: 140px; top: 25%; left: 42%; animation-delay: -4s; }
@keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-18px)} }
.az-promo__inner { position: relative; z-index: 2; display: flex; align-items: center; justify-content: space-between; gap: 40px; flex-wrap: wrap; }
.az-promo__text { color: #fff; }
.az-promo__ey { font-size: .8rem; font-weight: 700; opacity: .8; text-transform: uppercase; letter-spacing: .1em; margin-bottom: 8px; }
.az-promo__h2 { font-size: clamp(1.6rem, 3vw, 2.5rem); font-weight: 900; margin: 0 0 10px; line-height: 1.2; }
.az-promo__p  { font-size: .97rem; opacity: .85; max-width: 420px; line-height: 1.65; }
.az-promo__coupon {
  display: flex; align-items: center; gap: 10px;
  background: rgba(255,255,255,.2); border: 2px dashed rgba(255,255,255,.5);
  border-radius: 10px; padding: 12px 20px; margin-top: 20px; cursor: pointer;
  transition: var(--az-tr); width: fit-content;
}
.az-promo__coupon:hover { background: rgba(255,255,255,.3); }
.az-promo__cl { font-size: .76rem; color: rgba(255,255,255,.7); }
.az-promo__cc { font-size: 1.1rem; font-weight: 900; color: #fff; letter-spacing: .12em; }
.az-promo__ci { color: rgba(255,255,255,.8); }
.az-promo__cta { display: flex; flex-direction: column; align-items: flex-start; gap: 14px; }
.az-promo__note { display: flex; align-items: center; gap: 6px; color: rgba(255,255,255,.75); font-size: .83rem; }

/* ============================================================
   8. BRANDS
   ============================================================ */
.az-brands__wrap { overflow: hidden; position: relative; }
.az-brands__wrap::before, .az-brands__wrap::after {
  content: ''; position: absolute; top: 0; bottom: 0; width: 80px; z-index: 2;
}
.az-brands__wrap::before { left: 0; background: linear-gradient(to right, #fff, transparent); }
.az-brands__wrap::after  { right: 0; background: linear-gradient(to left, #fff, transparent); }
.az-brands__track { display: flex; gap: 24px; animation: scroll-brands 28s linear infinite; width: max-content; }
.az-brands__track:hover { animation-play-state: paused; }
@keyframes scroll-brands { from{transform:translateX(0)} to{transform:translateX(-50%)} }
.az-brand {
  flex-shrink: 0; width: 140px; height: 68px;
  background: #fff; border: 1px solid var(--az-border);
  border-radius: var(--az-r); display: flex; align-items: center; justify-content: center;
  padding: 10px 18px; transition: var(--az-tr); filter: grayscale(1); opacity: .45;
}
.az-brand:hover { filter: none; opacity: 1; border-color: var(--az-primary); box-shadow: var(--az-shadow); }
.az-brand span { font-size: .85rem; font-weight: 800; color: var(--az-muted); }

/* ============================================================
   9. TESTIMONIALS
   ============================================================ */
.az-testi__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.az-testi {
  background: #fff; border: 1px solid var(--az-border);
  border-radius: var(--az-r-lg); padding: 28px;
  transition: var(--az-tr); position: relative;
}
.az-testi:hover { transform: translateY(-6px); box-shadow: var(--az-shadow-hv); border-color: var(--az-primary); }
.az-testi::before { content: '"'; position: absolute; top: 14px; left: 22px; font-size: 4rem; color: var(--az-primary); opacity: .1; font-family: Georgia, serif; line-height: 1; }
.az-testi__stars { color: var(--az-accent); font-size: .95rem; margin-bottom: 14px; }
.az-testi__text { font-size: .93rem; color: var(--az-muted); line-height: 1.75; margin-bottom: 20px; }
.az-testi__author { display: flex; align-items: center; gap: 12px; }
.az-testi__av { width: 44px; height: 44px; border-radius: 50%; background: var(--az-primary-lt); display: flex; align-items: center; justify-content: center; font-size: 1.1rem; font-weight: 800; color: var(--az-primary); flex-shrink: 0; }
.az-testi__name { font-size: .9rem; font-weight: 700; }
.az-testi__role { font-size: .76rem; color: var(--az-muted); }
.az-testi__ver  { display: flex; align-items: center; gap: 4px; font-size: .7rem; color: var(--az-success); margin-top: 2px; }
.az-testi__ver .ms { font-size: .85rem; }
.az-stats-row { display: flex; align-items: center; justify-content: center; gap: 48px; flex-wrap: wrap; margin-top: 56px; }
.az-stats-row__div { width: 1px; height: 40px; background: var(--az-border); }
.az-stats-row__n { font-size: 2rem; font-weight: 900; color: var(--az-primary); line-height: 1; }
.az-stats-row__l { font-size: .8rem; color: var(--az-muted); margin-top: 4px; }

/* ============================================================
   10. FAQ
   ============================================================ */
.az-faq { max-width: 760px; margin: 0 auto; }
.az-faq__item {
  background: #fff; border: 1px solid var(--az-border);
  border-radius: var(--az-r); margin-bottom: 12px; overflow: hidden; transition: var(--az-tr);
}
.az-faq__item:hover { border-color: var(--az-primary); }
.az-faq__item[open] { border-color: var(--az-primary); box-shadow: 0 0 0 3px rgba(37,99,235,.08); }
.az-faq__item summary {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20px 24px; cursor: pointer; list-style: none;
  font-size: .95rem; font-weight: 700; gap: 16px;
}
.az-faq__item summary::-webkit-details-marker { display: none; }
.az-faq__ico { color: var(--az-primary); transition: transform .3s ease; flex-shrink: 0; }
.az-faq__item[open] .az-faq__ico { transform: rotate(180deg); }
.az-faq__ans { padding: 0 24px 20px; font-size: .92rem; color: var(--az-muted); line-height: 1.75; }

/* ============================================================
   11. CTA BOTTOM
   ============================================================ */
.az-cta {
  background: linear-gradient(135deg, var(--az-primary) 0%, var(--az-primary-dk) 100%);
  position: relative; overflow: hidden; text-align: center;
}
.az-cta__pat {
  position: absolute; inset: 0; opacity: .06;
  background-image: radial-gradient(circle, #fff 1px, transparent 1px);
  background-size: 28px 28px;
}
.az-cta__con { position: relative; z-index: 2; }
.az-cta__h2 { font-size: clamp(1.8rem, 3.5vw, 2.6rem); font-weight: 900; color: #fff; margin: 0 0 16px; }
.az-cta__p  { font-size: 1.02rem; color: rgba(255,255,255,.75); max-width: 500px; margin: 0 auto 36px; line-height: 1.7; }
.az-cta__btns { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
.az-cta__trust { display: flex; align-items: center; justify-content: center; gap: 28px; margin-top: 32px; flex-wrap: wrap; }
.az-cta__ti { display: flex; align-items: center; gap: 6px; color: rgba(255,255,255,.6); font-size: .82rem; }
.az-cta__ti .ms { font-size: 1rem; color: var(--az-accent); }

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media (max-width: 1024px) {
  .az-cats__grid { grid-template-columns: repeat(2, 1fr); }
  .az-cat--wide  { grid-column: span 2; }
  .az-prods__grid { grid-template-columns: repeat(2, 1fr); }
  .az-flash__grid { grid-template-columns: repeat(2, 1fr); }
  .az-testi__grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 768px) {
  :root { --az-py: 56px; }
  .az-trust__grid { grid-template-columns: repeat(2, 1fr); }
  .az-trust__item { border-left: none; border-bottom: 1px solid var(--az-border); }
  .az-flash__top  { flex-direction: column; align-items: flex-start; }
  .az-promo__inner { flex-direction: column; }
  .az-testi__grid { grid-template-columns: 1fr; }
  .az-hero__stats { gap: 20px; }
}
@media (max-width: 480px) {
  .az-trust__grid { grid-template-columns: 1fr; }
  .az-cats__grid  { grid-template-columns: 1fr; }
  .az-cat--wide   { grid-column: span 1; }
  .az-prods__grid { grid-template-columns: 1fr; }
  .az-flash__grid { grid-template-columns: 1fr; }
  .az-hero__btns  { flex-direction: column; }
  .az-cd__n { width: 44px; height: 44px; font-size: 1.3rem; }
}
</style>
{% endblock %}

{% block content %}
<div class="az-page">

{# ============================================================
   SECTION 1 — شريط الإعلانات
   ============================================================ #}
<div class="az-topbar" id="az-topbar">
  <button class="az-topbar__x" onclick="document.getElementById('az-topbar').style.display='none'" aria-label="إغلاق">
    <span class="ms material-symbols-outlined" style="font-size:1rem;">close</span>
  </button>
  <div class="az-topbar__inner">
    <span class="az-topbar__badge">🔥 عرض</span>
    <span>{{ 'شحن مجاني على جميع الطلبات فوق 200 ريال' | trans }}</span>
    <a href="{{ store.urls.products }}">{{ 'تسوق الآن ←' | trans }}</a>
  </div>
</div>
<div class="az-label">قسم: شريط الإعلانات — ثيم: ازدهار</div>

{# ============================================================
   SECTION 2 — الصورة الرئيسية (Hero)
   ============================================================ #}
<section class="az-hero">
  <div class="az-hero__bg" id="az-hero-bg"></div>
  <div class="az-hero__ov"></div>
  <div class="az-con" style="width:100%;">
    <div class="az-hero__con">
      <div class="az-hero__badge">
        <span class="ms material-symbols-outlined" style="font-size:.9rem;">local_fire_department</span>
        {{ 'مجموعة جديدة لهذا الموسم' | trans }}
      </div>
      <h1 class="az-hero__h1">
        {{ store.name | default('اكتشف') }}<br>
        <span>{{ 'أفضل المنتجات' | trans }}</span><br>
        {{ 'بأسعار لا تُقاوم' | trans }}
      </h1>
      <p class="az-hero__p">{{ 'تسوق من أرقى المنتجات المختارة بعناية. جودة عالية، أسعار منافسة، وتوصيل سريع لباب منزلك.' | trans }}</p>
      <div class="az-hero__btns">
        <a href="{{ store.urls.products }}" class="az-btn az-btn--amber">
          <span class="ms material-symbols-outlined">shopping_bag</span>
          {{ 'تسوق الآن' | trans }}
        </a>
        <a href="{{ store.urls.categories ?? '#' }}" class="az-btn az-btn--wghost">
          {{ 'استعرض التصنيفات' | trans }}
        </a>
      </div>
      <div class="az-hero__stats">
        <div>
          <div class="az-hero__stat-n">+500</div>
          <div class="az-hero__stat-l">{{ 'منتج متاح' | trans }}</div>
        </div>
        <div class="az-hero__div"></div>
        <div>
          <div class="az-hero__stat-n">+10K</div>
          <div class="az-hero__stat-l">{{ 'عميل راضٍ' | trans }}</div>
        </div>
        <div class="az-hero__div"></div>
        <div>
          <div class="az-hero__stat-n">4.9★</div>
          <div class="az-hero__stat-l">{{ 'تقييم المتجر' | trans }}</div>
        </div>
      </div>
    </div>
  </div>
  <div class="az-hero__scroll">
    <span>{{ 'اكتشف المزيد' | trans }}</span>
    <div class="az-hero__scroll-dot"></div>
  </div>
</section>
<div class="az-label">قسم: الصورة الرئيسية — ثيم: ازدهار</div>

{# ============================================================
   SECTION 3 — مميزات المتجر (Trust Bar)
   ============================================================ #}
<div class="az-trust az-r">
  <div class="az-con">
    <div class="az-trust__grid">
      <div class="az-trust__item">
        <div class="az-trust__icon"><span class="ms material-symbols-outlined">local_shipping</span></div>
        <div class="az-trust__t"><strong>{{ 'شحن مجاني' | trans }}</strong><span>{{ 'على الطلبات فوق 200 ريال' | trans }}</span></div>
      </div>
      <div class="az-trust__item">
        <div class="az-trust__icon"><span class="ms material-symbols-outlined">verified_user</span></div>
        <div class="az-trust__t"><strong>{{ 'منتجات أصلية 100%' | trans }}</strong><span>{{ 'ضمان الجودة والأصالة' | trans }}</span></div>
      </div>
      <div class="az-trust__item">
        <div class="az-trust__icon"><span class="ms material-symbols-outlined">autorenew</span></div>
        <div class="az-trust__t"><strong>{{ 'إرجاع مجاني' | trans }}</strong><span>{{ 'خلال 14 يوماً من الاستلام' | trans }}</span></div>
      </div>
      <div class="az-trust__item">
        <div class="az-trust__icon"><span class="ms material-symbols-outlined">headset_mic</span></div>
        <div class="az-trust__t"><strong>{{ 'دعم 24/7' | trans }}</strong><span>{{ 'فريق دعم متاح دائماً' | trans }}</span></div>
      </div>
    </div>
  </div>
</div>
<div class="az-label">قسم: مميزات المتجر — ثيم: ازدهار</div>

{# ============================================================
   SECTION 4 — التصنيفات
   ============================================================ #}
<section class="az-sec az-sec--gray">
  <div class="az-con">
    <div class="az-head az-r">
      <div class="az-eyebrow">{{ 'تصفح حسب' | trans }}</div>
      <h2 class="az-h2">{{ 'التصنيفات الرئيسية' | trans }}</h2>
      <p class="az-sub">{{ 'اكتشف مجموعتنا المتنوعة من المنتجات المنظمة في تصنيفات سهلة التصفح' | trans }}</p>
    </div>

    {% if store.categories is defined and store.categories | length > 0 %}
      <div class="az-cats__grid">
        {% for cat in store.categories | slice(0, 6) %}
          <a href="{{ cat.url }}" class="az-cat az-r d{{ loop.index <= 4 ? loop.index : 4 }} {% if loop.index == 1 %}az-cat--wide{% endif %}">
            {% if cat.image %}
              <img class="az-cat__img" src="{{ cat.image }}" alt="{{ cat.name }}" loading="lazy">
            {% else %}
              <div class="az-cat__img" style="background:linear-gradient(135deg,#2563eb,#7c3aed);width:100%;height:100%;"></div>
            {% endif %}
            <div class="az-cat__ov"></div>
            <div class="az-cat__body">
              <div class="az-cat__name">{{ cat.name }}</div>
              {% if cat.products_count is defined %}<div class="az-cat__count">{{ cat.products_count }} {{ 'منتج' | trans }}</div>{% endif %}
              <div class="az-cat__cta">{{ 'تسوق الآن' | trans }} <span class="ms material-symbols-outlined" style="font-size:.8rem;">arrow_back</span></div>
            </div>
          </a>
        {% endfor %}
      </div>
    {% else %}
      {# Demo categories #}
      <div class="az-cats__grid">
        {% set dcats = [
          {n:'الملابس والأزياء',   g:'#2563eb,#7c3aed', i:'checkroom'},
          {n:'الإلكترونيات',       g:'#0f172a,#1e3a5f', i:'devices'},
          {n:'المنزل والديكور',    g:'#059669,#0d9488', i:'home'},
          {n:'الرياضة واللياقة',   g:'#dc2626,#ea580c', i:'fitness_center'},
          {n:'الجمال والعناية',    g:'#be185d,#9333ea', i:'spa'},
          {n:'الأطفال والألعاب',   g:'#d97706,#ca8a04', i:'toys'}
        ] %}
        {% for c in dcats %}
          <a href="{{ store.urls.categories ?? '#' }}" class="az-cat az-r d{{ loop.index <= 4 ? loop.index : 4 }} {% if loop.index == 1 %}az-cat--wide{% endif %}">
            <div class="az-cat__img" style="background:linear-gradient(135deg,#{{ c.g }});width:100%;height:100%;display:flex;align-items:center;justify-content:center;">
              <span class="ms material-symbols-outlined" style="font-size:3.5rem;color:rgba(255,255,255,.2);">{{ c.i }}</span>
            </div>
            <div class="az-cat__ov"></div>
            <div class="az-cat__body">
              <div class="az-cat__name">{{ c.n }}</div>
              <div class="az-cat__count">{{ 'استعرض المنتجات' | trans }}</div>
              <div class="az-cat__cta">{{ 'تسوق الآن' | trans }} <span class="ms material-symbols-outlined" style="font-size:.8rem;">arrow_back</span></div>
            </div>
          </a>
        {% endfor %}
      </div>
    {% endif %}

    <div style="text-align:center;margin-top:36px;" class="az-r">
      <a href="{{ store.urls.categories ?? '#' }}" class="az-btn az-btn--ghost">
        {{ 'عرض جميع التصنيفات' | trans }}
        <span class="ms material-symbols-outlined">arrow_back</span>
      </a>
    </div>
  </div>
</section>
<div class="az-label">قسم: التصنيفات — ثيم: ازدهار</div>

{# ============================================================
   SECTION 5 — المنتجات المميزة
   ============================================================ #}
<section class="az-sec az-sec--white">
  <div class="az-con">
    <div class="az-head az-r">
      <div class="az-eyebrow">{{ 'الأكثر مبيعاً' | trans }}</div>
      <h2 class="az-h2">{{ 'المنتجات المميزة' | trans }}</h2>
      <p class="az-sub">{{ 'منتجات مختارة بعناية لتناسب أذواقكم وتلبي احتياجاتكم' | trans }}</p>
    </div>

    {% set featured = store.products.featured ?? [] %}
    {% if featured | length > 0 %}
      <div class="az-prods__grid">
        {% for p in featured | slice(0, 8) %}
          <div class="az-prod az-r d{{ loop.index <= 4 ? loop.index : 4 }}">
            <div class="az-prod__img-w">
              <img class="az-prod__img" src="{{ p.image.url ?? '' }}" alt="{{ p.name }}" loading="lazy">
              {% if p.is_new %}<span class="az-prod__badge az-prod__badge--new">{{ 'جديد' | trans }}</span>{% endif %}
              {% if p.discount %}<span class="az-prod__badge">-{{ p.discount }}%</span>{% endif %}
              <button class="az-prod__wish"><span class="ms material-symbols-outlined" style="font-size:1.1rem;">favorite_border</span></button>
            </div>
            <div class="az-prod__body">
              <div class="az-prod__cat">{{ p.category.name ?? '' }}</div>
              <div class="az-prod__name">{{ p.name }}</div>
              <div class="az-prod__stars">★★★★★ <span style="font-size:.75rem;color:var(--az-muted);">({{ p.rating_count ?? 0 }})</span></div>
              <div class="az-prod__foot">
                <div>
                  {% if p.sale_price %}<span class="az-prod__old">{{ p.price | money }}</span>{% endif %}
                  <span class="az-prod__price">{{ (p.sale_price ?? p.price) | money }}</span>
                </div>
                <button class="az-prod__add"><span class="ms material-symbols-outlined" style="font-size:1.1rem;">add_shopping_cart</span></button>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      {# Demo products #}
      <div class="az-prods__grid">
        {% set dprods = [
          {n:'منتج مميز رقم 1', p:'299', o:'399', b:'خصم 25%', c:'الملابس', g:'2563eb,7c3aed'},
          {n:'منتج مميز رقم 2', p:'149', o:'',    b:'جديد',    c:'الإلكترونيات', g:'0f172a,1e3a5f'},
          {n:'منتج مميز رقم 3', p:'599', o:'799', b:'خصم 25%', c:'المنزل', g:'059669,0d9488'},
          {n:'منتج مميز رقم 4', p:'89',  o:'',    b:'',        c:'الرياضة', g:'dc2626,ea580c'},
          {n:'منتج مميز رقم 5', p:'349', o:'449', b:'خصم 22%', c:'الجمال', g:'be185d,9333ea'},
          {n:'منتج مميز رقم 6', p:'199', o:'',    b:'جديد',    c:'الأطفال', g:'d97706,ca8a04'},
          {n:'منتج مميز رقم 7', p:'459', o:'599', b:'خصم 23%', c:'الملابس', g:'0891b2,0e7490'},
          {n:'منتج مميز رقم 8', p:'129', o:'',    b:'',        c:'الإلكترونيات', g:'16a34a,15803d'}
        ] %}
        {% for p in dprods %}
          <div class="az-prod az-r d{{ loop.index <= 4 ? loop.index : 4 }}">
            <div class="az-prod__img-w">
              <div class="az-prod__img" style="background:linear-gradient(135deg,#{{ p.g }});display:flex;align-items:center;justify-content:center;">
                <span class="ms material-symbols-outlined" style="font-size:3rem;color:rgba(255,255,255,.25);">inventory_2</span>
              </div>
              {% if p.b %}<span class="az-prod__badge {% if p.b == 'جديد' %}az-prod__badge--new{% endif %}">{{ p.b }}</span>{% endif %}
              <button class="az-prod__wish"><span class="ms material-symbols-outlined" style="font-size:1.1rem;">favorite_border</span></button>
            </div>
            <div class="az-prod__body">
              <div class="az-prod__cat">{{ p.c }}</div>
              <div class="az-prod__name">{{ p.n }}</div>
              <div class="az-prod__stars">★★★★★ <span style="font-size:.75rem;color:var(--az-muted);">({{ loop.index * 11 + 7 }})</span></div>
              <div class="az-prod__foot">
                <div>
                  {% if p.o %}<span class="az-prod__old">{{ p.o }} ر.س</span>{% endif %}
                  <span class="az-prod__price">{{ p.p }} ر.س</span>
                </div>
                <button class="az-prod__add"><span class="ms material-symbols-outlined" style="font-size:1.1rem;">add_shopping_cart</span></button>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    <div style="text-align:center;margin-top:40px;" class="az-r">
      <a href="{{ store.urls.products }}" class="az-btn az-btn--blue">
        {{ 'عرض جميع المنتجات' | trans }}
        <span class="ms material-symbols-outlined">arrow_back</span>
      </a>
    </div>
  </div>
</section>
<div class="az-label">قسم: المنتجات المميزة — ثيم: ازدهار</div>

{# ============================================================
   SECTION 6 — عروض الفلاش
   ============================================================ #}
<section class="az-sec az-flash">
  <div class="az-con">
    <div class="az-flash__top az-r">
      <div class="az-flash__left">
        <span class="az-flash__fire">⚡</span>
        <div>
          <h2 class="az-flash__h2">{{ 'عروض الفلاش' | trans }}</h2>
          <p class="az-flash__sub">{{ 'عروض محدودة الوقت — لا تفوّتها!' | trans }}</p>
        </div>
      </div>
      <div class="az-cd">
        <div class="az-cd__u"><div class="az-cd__n" id="az-h">00</div><div class="az-cd__l">{{ 'ساعة' | trans }}</div></div>
        <div class="az-cd__sep">:</div>
        <div class="az-cd__u"><div class="az-cd__n" id="az-m">00</div><div class="az-cd__l">{{ 'دقيقة' | trans }}</div></div>
        <div class="az-cd__sep">:</div>
        <div class="az-cd__u"><div class="az-cd__n" id="az-s">00</div><div class="az-cd__l">{{ 'ثانية' | trans }}</div></div>
      </div>
    </div>
    <div class="az-flash__grid">
      {% set fitems = [
        {n:'منتج عرض الفلاش 1', d:'40', pr:65, st:'تبقى 8 قطع',  g:'ef4444,dc2626'},
        {n:'منتج عرض الفلاش 2', d:'35', pr:80, st:'تبقى 5 قطع',  g:'f97316,ea580c'},
        {n:'منتج عرض الفلاش 3', d:'50', pr:45, st:'تبقى 12 قطعة',g:'8b5cf6,7c3aed'},
        {n:'منتج عرض الفلاش 4', d:'30', pr:90, st:'تبقى 3 قطع',  g:'10b981,059669'}
      ] %}
      {% for fi in fitems %}
        <div class="az-fc az-r d{{ loop.index }}">
          <div class="az-fc__img-w">
            <div class="az-fc__img" style="background:linear-gradient(135deg,#{{ fi.g }});display:flex;align-items:center;justify-content:center;">
              <span class="ms material-symbols-outlined" style="font-size:3.5rem;color:rgba(255,255,255,.2);">local_offer</span>
            </div>
            <span class="az-fc__disc">-{{ fi.d }}%</span>
          </div>
          <div class="az-fc__body">
            <div class="az-fc__name">{{ fi.n }}</div>
            <div class="az-fc__bar-w"><div class="az-fc__bar" data-w="{{ fi.pr }}"></div></div>
            <div class="az-fc__stock">{{ fi.st }}</div>
            <div class="az-fc__foot">
              <div>
                <span class="az-fc__old">{{ (200 + loop.index * 50) }} ر.س</span>
                <span class="az-fc__price">{{ ((200 + loop.index * 50) * (100 - fi.d | int) // 100) }} ر.س</span>
              </div>
              <button class="az-fc__add">{{ 'أضف للسلة' | trans }}</button>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
<div class="az-label">قسم: عروض الفلاش — ثيم: ازدهار</div>

{# ============================================================
   SECTION 7 — البانر الترويجي
   ============================================================ #}
<section class="az-sec az-promo">
  <div class="az-promo__c"></div>
  <div class="az-promo__c"></div>
  <div class="az-promo__c"></div>
  <div class="az-con">
    <div class="az-promo__inner az-r">
      <div class="az-promo__text">
        <div class="az-promo__ey">{{ 'عرض حصري' | trans }}</div>
        <h2 class="az-promo__h2">{{ 'خصم 20% على أول طلب' | trans }}</h2>
        <p class="az-promo__p">{{ 'سجّل الآن واحصل على خصم حصري على أول طلب لك. العرض محدود لأول 100 عميل فقط!' | trans }}</p>
        <div class="az-promo__coupon" id="az-coupon" title="{{ 'انقر لنسخ الكود' | trans }}">
          <div>
            <div class="az-promo__cl">{{ 'كود الخصم' | trans }}</div>
            <div class="az-promo__cc" id="az-coupon-code">AZDAHAR20</div>
          </div>
          <span class="ms material-symbols-outlined az-promo__ci" id="az-coupon-icon">content_copy</span>
        </div>
      </div>
      <div class="az-promo__cta">
        <a href="{{ store.urls.products }}" class="az-btn az-btn--white" style="font-size:1.05rem;">
          <span class="ms material-symbols-outlined">shopping_bag</span>
          {{ 'تسوق الآن' | trans }}
        </a>
        <div class="az-promo__note">
          <span class="ms material-symbols-outlined" style="font-size:1rem;">schedule</span>
          {{ 'العرض ينتهي قريباً' | trans }}
