{% block scripts %}
<script>
(function () {
  /* ── Scroll Reveal ── */
  var els = document.querySelectorAll('.az-r');
  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { e.target.classList.add('on'); io.unobserve(e.target); }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    els.forEach(function (el) { io.observe(el); });
  } else {
    els.forEach(function (el) { el.classList.add('on'); });
  }

  /* ── Hero BG Zoom ── */
  var bg = document.getElementById('az-hero-bg');
  if (bg) setTimeout(function () { bg.classList.add('loaded'); }, 200);

  /* ── Countdown ── */
  var end = new Date();
  end.setHours(end.getHours() + 11, end.getMinutes() + 47, end.getSeconds() + 22);
  function pad(n) { return String(n).padStart(2, '0'); }
  function flip(el, v) {
    if (!el || el.textContent === v) return;
    el.classList.add('flip');
    setTimeout(function () { el.textContent = v; el.classList.remove('flip'); }, 150);
  }
  function tick() {
    var d = end - Date.now();
    if (d <= 0) return;
    flip(document.getElementById('az-h'), pad(Math.floor(d / 3600000)));
    flip(document.getElementById('az-m'), pad(Math.floor((d % 3600000) / 60000)));
    flip(document.getElementById('az-s'), pad(Math.floor((d % 60000) / 1000)));
  }
  tick(); setInterval(tick, 1000);

  /* ── Coupon Copy ── */
  var coupon = document.getElementById('az-coupon');
  var icon   = document.getElementById('az-coupon-icon');
  if (coupon && icon) {
    coupon.addEventListener('click', function () {
      var code = document.getElementById('az-coupon-code');
      if (code && navigator.clipboard) {
        navigator.clipboard.writeText(code.textContent.trim()).then(function () {
          icon.textContent = 'check_circle';
          setTimeout(function () { icon.textContent = 'content_copy'; }, 2500);
        });
      }
    });
  }

  /* ── Flash Progress Bars ── */
  var bars = document.querySelectorAll('.az-fc__bar');
  if ('IntersectionObserver' in window) {
    var bio = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          e.target.style.width = (e.target.getAttribute('data-w') || '50') + '%';
          bio.unobserve(e.target);
        }
      });
    }, { threshold: 0.3 });
    bars.forEach(function (b) { b.style.width = '0'; bio.observe(b); });
  }
})();
</script>
{% endblock %}
