{#
| Variable   | Type   | Description        |
|------------|--------|--------------------|
| page       | object |                    |
| page.title | string | *could be html     |
| page.slug  | string | ex: "cat.show"     |
#}
{% extends "layouts.master" %}

{% block styles %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet">

<style>
/* ================================================================
   ثيم ازدهار — تصميم احترافي كامل مع أنيميشن
   ================================================================ */

/* ---------- متغيرات الألوان ---------- */
:root {
  --az-dark:      #2F2824;
  --az-gold:      #87602C;
  --az-gold-lt:   #a8783a;
  --az-cream:     #fcf9f6;
  --az-white:     #ffffff;
  --az-gray:      #6b7280;
  --az-gray-lt:   #f1f5f9;
  --az-shadow:    0 4px 24px rgba(47,40,36,.10);
  --az-shadow-lg: 0 12px 48px rgba(47,40,36,.18);
  --az-radius:    1.25rem;
  --az-radius-lg: 1.75rem;
  --az-transition: .35s cubic-bezier(.4,0,.2,1);
}

/* ---------- ريست عام ---------- */
.az-page *, .az-page *::before, .az-page *::after { box-sizing: border-box; }
.az-page { font-family: 'Tajawal', sans-serif; direction: rtl; overflow-x: hidden; }
.az-page a { text-decoration: none; color: inherit; }
.az-page img { display: block; max-width: 100%; }

/* ---------- أنيميشن الظهور عند التمرير ---------- */
@keyframes az-fadeUp {
  from { opacity: 0; transform: translateY(40px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes az-fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}
@keyframes az-scaleIn {
  from { opacity: 0; transform: scale(.92); }
  to   { opacity: 1; transform: scale(1); }
}
@keyframes az-slideRight {
  from { opacity: 0; transform: translateX(60px); }
  to   { opacity: 1; transform: translateX(0); }
}
@keyframes az-pulse {
  0%, 100% { transform: scale(1); }
  50%       { transform: scale(1.06); }
}
@keyframes az-shimmer {
  0%   { background-position: -200% center; }
  100% { background-position:  200% center; }
}
@keyframes az-float {
  0%, 100% { transform: translateY(0); }
  50%       { transform: translateY(-10px); }
}

.az-reveal {
  opacity: 0;
  transform: translateY(36px);
  transition: opacity .7s ease, transform .7s ease;
}
.az-reveal.az-visible {
  opacity: 1;
  transform: translateY(0);
}
.az-reveal-delay-1 { transition-delay: .1s; }
.az-reveal-delay-2 { transition-delay: .2s; }
.az-reveal-delay-3 { transition-delay: .3s; }
.az-reveal-delay-4 { transition-delay: .4s; }

/* ---------- مساحات القسم ---------- */
.az-section {
  padding: 5rem 1.25rem;
}
@media (min-width: 768px)  { .az-section { padding: 5rem 3rem; } }
@media (min-width: 1280px) { .az-section { padding: 5rem 8rem; } }

/* ---------- رأس القسم ---------- */
.az-section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 3rem;
}
.az-section-eyebrow {
  display: flex;
  align-items: center;
  gap: .6rem;
  margin-bottom: .75rem;
}
.az-section-eyebrow__line {
  width: 2.5rem; height: 2px;
  background: var(--az-gold);
  border-radius: 2px;
}
.az-section-eyebrow__text {
  font-size: .72rem;
  font-weight: 800;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--az-gold);
}
.az-section-title {
  font-size: clamp(1.6rem, 3vw, 2.4rem);
  font-weight: 900;
  color: var(--az-dark);
  line-height: 1.2;
  margin: 0 0 .4rem;
}
.az-section-subtitle {
  font-size: .95rem;
  color: var(--az-gray);
  margin: 0;
}
.az-view-all {
  display: inline-flex;
  align-items: center;
  gap: .4rem;
  font-size: .875rem;
  font-weight: 700;
  color: var(--az-gold);
  white-space: nowrap;
  padding: .5rem 1.25rem;
  border: 1.5px solid rgba(135,96,44,.3);
  border-radius: 9999px;
  transition: var(--az-transition);
}
.az-view-all:hover {
  background: var(--az-gold);
  color: #fff;
  border-color: var(--az-gold);
}

/* ================================================================
   1. HERO SECTION
   ================================================================ */
.az-hero {
  padding: 1.25rem;
}
@media (min-width: 768px)  { .az-hero { padding: 2rem 3rem; } }
@media (min-width: 1280px) { .az-hero { padding: 2rem 8rem; } }

.az-hero__wrap {
  position: relative;
  min-height: 620px;
  border-radius: var(--az-radius-lg);
  overflow: hidden;
  display: flex;
  align-items: center;
  padding: 3rem 2rem;
}
@media (min-width: 768px) { .az-hero__wrap { padding: 4rem 5rem; min-height: 680px; } }

/* طبقة الخلفية */
.az-hero__bg {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center;
  transform: scale(1.04);
  transition: transform 8s ease;
  will-change: transform;
}
.az-hero__wrap:hover .az-hero__bg { transform: scale(1.08); }

/* طبقة التدرج */
.az-hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    270deg,
    rgba(47,40,36,.95) 0%,
    rgba(47,40,36,.65) 45%,
    rgba(47,40,36,.15) 100%
  );
}

/* حبوب الضوء الزخرفية */
.az-hero__glow {
  position: absolute;
  width: 500px; height: 500px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(135,96,44,.25) 0%, transparent 70%);
  top: -100px; left: -100px;
  pointer-events: none;
  animation: az-float 6s ease-in-out infinite;
}

.az-hero__content {
  position: relative;
  z-index: 10;
  max-width: 38rem;
  animation: az-slideRight .9s ease both;
}

.az-hero__eyebrow {
  display: flex;
  align-items: center;
  gap: .75rem;
  margin-bottom: 1.75rem;
}
.az-hero__eyebrow-line {
  width: 3rem; height: 2px;
  background: var(--az-gold);
  border-radius: 2px;
}
.az-hero__eyebrow-text {
  font-size: .72rem;
  font-weight: 800;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--az-gold);
}

.az-hero__title {
  font-size: clamp(2.8rem, 6vw, 5.5rem);
  font-weight: 900;
  color: #fff;
  line-height: 1.15;
  margin: 0 0 1.5rem;
}
.az-hero__title-highlight {
  color: var(--az-gold);
  position: relative;
  display: inline-block;
}
/* خط تحت الكلمة المميزة */
.az-hero__title-highlight::after {
  content: '';
  position: absolute;
  bottom: 4px; right: 0; left: 0;
  height: 3px;
  background: var(--az-gold);
  border-radius: 2px;
  opacity: .5;
}

.az-hero__desc {
  font-size: 1.1rem;
  color: rgba(255,255,255,.8);
  line-height: 1.85;
  margin: 0 0 2.5rem;
  max-width: 30rem;
}

.az-hero__btns {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
}

/* أزرار عامة */
.az-btn {
  display: inline-flex;
  align-items: center;
  gap: .5rem;
  font-family: 'Tajawal', sans-serif;
  font-weight: 800;
  border-radius: .875rem;
  padding: 1rem 2.25rem;
  font-size: 1rem;
  cursor: pointer;
  border: none;
  transition: var(--az-transition);
  text-decoration: none;
}
.az-btn--primary {
  background: var(--az-gold);
  color: #fff;
  box-shadow: 0 4px 20px rgba(135,96,44,.4);
}
.az-btn--primary:hover {
  background: var(--az-gold-lt);
  transform: translateY(-3px);
  box-shadow: 0 8px 28px rgba(135,96,44,.5);
}
.az-btn--outline {
  background: rgba(255,255,255,.12);
  color: #fff;
  border: 1.5px solid rgba(255,255,255,.4);
  backdrop-filter: blur(8px);
}
.az-btn--outline:hover {
  background: rgba(255,255,255,.22);
  transform: translateY(-3px);
}
.az-btn--dark {
  background: var(--az-dark);
  color: #fff;
}
.az-btn--dark:hover {
  background: #3d3430;
  transform: translateY(-2px);
}

/* إحصائيات الهيرو */
.az-hero__stats {
  display: flex;
  gap: 2.5rem;
  margin-top: 3rem;
  padding-top: 2rem;
  border-top: 1px solid rgba(255,255,255,.15);
}
.az-hero__stat-num {
  font-size: 1.8rem;
  font-weight: 900;
  color: var(--az-gold);
  line-height: 1;
}
.az-hero__stat-label {
  font-size: .8rem;
  color: rgba(255,255,255,.65);
  margin-top: .25rem;
}

/* ================================================================
   2. FEATURES BAR
   ================================================================ */
.az-features {
  background: var(--az-cream);
  padding: 0 1.25rem;
}
@media (min-width: 768px)  { .az-features { padding: 0 3rem; } }
@media (min-width: 1280px) { .az-features { padding: 0 8rem; } }

.az-features__inner {
  background: var(--az-white);
  border-radius: var(--az-radius-lg);
  box-shadow: var(--az-shadow);
  padding: 2.5rem 2rem;
  display: grid;
  grid-template-columns: 1fr;
  gap: 0;
  transform: translateY(-3rem);
  position: relative;
  z-index: 20;
}
@media (min-width: 640px)  { .az-features__inner { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 1024px) { .az-features__inner { grid-template-columns: repeat(4, 1fr); } }

.az-feature-item {
  display: flex;
  align-items: center;
  gap: 1.1rem;
  padding: 1.25rem 1.5rem;
  transition: var(--az-transition);
  border-radius: 1rem;
  cursor: default;
}
.az-feature-item:hover { background: var(--az-cream); }

/* فاصل رأسي بين العناصر */
@media (min-width: 1024px) {
  .az-feature-item:not(:last-child) {
    border-left: 1px solid var(--az-gray-lt);
  }
}

.az-feature-item__icon-wrap {
  width: 3.25rem; height: 3.25rem;
  border-radius: .875rem;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(135,96,44,.1);
  flex-shrink: 0;
  transition: var(--az-transition);
}
.az-feature-item:hover .az-feature-item__icon-wrap {
  background: var(--az-gold);
}
.az-feature-item__icon {
  font-size: 1.6rem;
  color: var(--az-gold);
  transition: var(--az-transition);
}
.az-feature-item:hover .az-feature-item__icon { color: #fff; }

.az-feature-item__title {
  font-weight: 800;
  font-size: 1rem;
  color: var(--az-dark);
  margin-bottom: .2rem;
}
.az-feature-item__desc {
  font-size: .8rem;
  color: var(--az-gray);
}

/* ================================================================
   3. CATEGORIES SECTION
   ================================================================ */
.az-categories { background: var(--az-cream); }

.az-categories__grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
}
@media (min-width: 768px) {
  .az-categories__grid {
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }
}

.az-cat-card {
  position: relative;
  aspect-ratio: 3/4;
  overflow: hidden;
  border-radius: var(--az-radius);
  display: block;
  cursor: pointer;
  box-shadow: var(--az-shadow);
}
.az-cat-card__bg {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center;
  transition: transform .7s cubic-bezier(.4,0,.2,1);
}
.az-cat-card:hover .az-cat-card__bg { transform: scale(1.1); }

.az-cat-card__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(47,40,36,.88) 0%,
    rgba(47,40,36,.35) 50%,
    transparent 100%
  );
  transition: var(--az-transition);
}
.az-cat-card:hover .az-cat-card__overlay {
  background: linear-gradient(
    to top,
    rgba(47,40,36,.95) 0%,
    rgba(47,40,36,.5) 55%,
    transparent 100%
  );
}

.az-cat-card__info {
  position: absolute;
  bottom: 0; right: 0; left: 0;
  padding: 1.5rem 1.25rem;
  transform: translateY(4px);
  transition: transform var(--az-transition);
}
.az-cat-card:hover .az-cat-card__info { transform: translateY(0); }

.az-cat-card__name {
  font-size: 1.15rem;
  font-weight: 900;
  color: #fff;
  margin-bottom: .3rem;
}
.az-cat-card__count {
  font-size: .78rem;
  color: rgba(255,255,255,.7);
  display: flex;
  align-items: center;
  gap: .3rem;
}
.az-cat-card__arrow {
  position: absolute;
  top: 1rem; left: 1rem;
  width: 2.25rem; height: 2.25rem;
  border-radius: 50%;
  background: rgba(255,255,255,.15);
  backdrop-filter: blur(6px);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 1.1rem;
  opacity: 0;
  transform: scale(.7);
  transition: var(--az-transition);
}
.az-cat-card:hover .az-cat-card__arrow {
  opacity: 1;
  transform: scale(1);
}

/* ================================================================
   4. FLASH SALES
   ================================================================ */
.az-flash { background: var(--az-white); }

.az-flash__head {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  margin-bottom: 2.5rem;
}
@media (min-width: 768px) {
  .az-flash__head {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
  }
}

.az-flash__title-wrap {
  display: flex;
  align-items: center;
  gap: 1.25rem;
}
.az-flash__icon-box {
  width: 3.5rem; height: 3.5rem;
  border-radius: 1rem;
  background: linear-gradient(135deg, var(--az-gold), var(--az-gold-lt));
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 1.75rem;
  box-shadow: 0 6px 20px rgba(135,96,44,.35);
  animation: az-pulse 2.5s ease-in-out infinite;
  flex-shrink: 0;
}

/* عداد تنازلي */
.az-countdown {
  display: flex;
  align-items: center;
  gap: .75rem;
  background: var(--az-cream);
  padding: 1rem 1.5rem;
  border-radius: 1rem;
  border: 1px solid rgba(135,96,44,.12);
}
.az-countdown__label {
  font-size: .7rem;
  font-weight: 800;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--az-dark);
  white-space: nowrap;
}
.az-countdown__digits {
  display: flex;
  align-items: center;
  gap: .35rem;
  direction: ltr;
}
.az-countdown__unit { display: flex; flex-direction: column; align-items: center; }
.az-countdown__num {
  width: 2.6rem; height: 2.6rem;
  border-radius: .5rem;
  background: var(--az-dark);
  color: #fff;
  font-weight: 900;
  font-size: 1.05rem;
  display: flex;
  align-items: center;
  justify-content: center;
  font-variant-numeric: tabular-nums;
  transition: transform .15s ease;
}
.az-countdown__num.az-flip { transform: scaleY(0); }
.az-countdown__sep {
  font-weight: 900;
  color: var(--az-dark);
  font-size: 1.2rem;
  margin-bottom: 1rem;
}
.az-countdown__unit-lbl {
  font-size: .6rem;
  font-weight: 700;
  color: var(--az-gray);
  margin-top: .3rem;
}

/* شبكة المنتجات */
.az-products-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
}
@media (min-width: 640px)  { .az-products-grid { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 1024px) { .az-products-grid { grid-template-columns: repeat(4, 1fr); } }

/* بطاقة المنتج */
.az-product-card {
  background: var(--az-white);
  border-radius: var(--az-radius);
  overflow: hidden;
  box-shadow: var(--az-shadow);
  border: 1.5px solid transparent;
  transition: var(--az-transition);
  display: flex;
  flex-direction: column;
}
.az-product-card:hover {
  border-color: rgba(135,96,44,.25);
  box-shadow: var(--az-shadow-lg);
  transform: translateY(-6px);
}

.az-product-card__img-wrap {
  position: relative;
  aspect-ratio: 1;
  overflow: hidden;
  background: var(--az-gray-lt);
}
.az-product-card__img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform .65s ease;
}
.az-product-card:hover .az-product-card__img { transform: scale(1.08); }

.az-product-card__badge {
  position: absolute;
  top: .75rem; right: .75rem;
  background: linear-gradient(135deg, var(--az-gold), var(--az-gold-lt));
  color: #fff;
  font-size: .65rem;
  font-weight: 800;
  padding: .3rem .8rem;
  border-radius: 9999px;
  letter-spacing: .05em;
  box-shadow: 0 2px 8px rgba(135,96,44,.4);
}
.az-product-card__wishlist {
  position: absolute;
  top: .75rem; left: .75rem;
  width: 2.25rem; height: 2.25rem;
  border-radius: 50%;
  background: rgba(255,255,255,.9);
  backdrop-filter: blur(4px);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--az-gray);
  font-size: 1.1rem;
  opacity: 0;
  transform: scale(.7);
  transition: var(--az-transition);
  cursor: pointer;
}
.az-product-card:hover .az-product-card__wishlist {
  opacity: 1;
  transform: scale(1);
}

.az-product-card__body {
  padding: 1.25rem;
  flex: 1;
  display: flex;
  flex-direction: column;
}
.az-product-card__name {
  font-weight: 800;
  font-size: 1rem;
  color: var(--az-dark);
  margin-bottom: .5rem;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
}
.az-product-card__stars {
  display: flex;
  align-items: center;
  gap: .15rem;
  margin-bottom: .75rem;
}
.az-product-card__star { font-size: .9rem; color: var(--az-gold); }
.az-product-card__reviews {
  font-size: .75rem;
  color: var(--az-gray);
  margin-right: .35rem;
}

.az-product-card__price-row {
  display: flex;
  align-items: baseline;
  gap: .5rem;
  margin-bottom: 1rem;
  flex-wrap: wrap;
}
.az-product-card__price {
  font-weight: 900;
  font-size: 1.4rem;
  color: var(--az-gold);
}
.az-product-card__old-price {
  font-size: .85rem;
  color: #9ca3af;
  text-decoration: line-through;
}

.az-product-card__add {
  width: 100%;
  padding: .875rem;
  background: var(--az-dark);
  color: #fff;
  font-family: 'Tajawal', sans-serif;
  font-weight: 700;
  font-size: .95rem;
  border: none;
  border-radius: .875rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: .5rem;
  transition: var(--az-transition);
  margin-top: auto;
}
.az-product-card__add:hover {
  background: var(--az-gold);
  box-shadow: 0 4px 16px rgba(135,96,44,.4);
}

/* ================================================================
   5. PROMO BANNER
   ================================================================ */
.az-promo { background: var(--az-cream); }

.az-promo__inner {
  position: relative;
  overflow: hidden;
  border-radius: var(--az-radius-lg);
  background: linear-gradient(135deg, var(--az-dark) 0%, #3d3430 40%, #2F2824 100%);
  padding: 4rem 3rem;
  display: flex;
  flex-direction: column;
  gap: 2.5rem;
  align-items: flex-start;
}
@media (min-width: 768px) {
  .az-promo__inner {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
  }
}

/* دوائر زخرفية */
.az-promo__circle {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}
.az-promo__circle--1 {
  width: 400px; height: 400px;
  background: radial-gradient(circle, rgba(135,96,44,.2) 0%, transparent 70%);
  top: -150px; left: -100px;
  animation: az-float 7s ease-in-out infinite;
}
.az-promo__circle--2 {
  width: 300px; height: 300px;
  background: radial-gradient(circle, rgba(135,96,44,.12) 0%, transparent 70%);
  bottom: -100px; right: -50px;
  animation: az-float 9s ease-in-out infinite reverse;
}

.az-promo__content { position: relative; z-index: 2; }
.az-promo__badge {
  display: inline-flex;
  align-items: center;
  gap: .4rem;
  background: rgba(135,96,44,.25);
  border: 1px solid rgba(135,96,44,.4);
  color: var(--az-gold);
  font-size: .72rem;
  font-weight: 800;
  letter-spacing: .12em;
  text-transform: uppercase;
  padding: .4rem 1rem;
  border-radius: 9999px;
  margin-bottom: 1.25rem;
}
.az-promo__title {
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  font-weight: 900;
  color: #fff;
  line-height: 1.2;
  margin: 0 0 1rem;
}
.az-promo__highlight { color: var(--az-gold); }
.az-promo__desc {
  font-size: 1rem;
  color: rgba(255,255,255,.7);
  line-height: 1.75;
  max-width: 28rem;
}
.az-promo__actions {
  position: relative;
  z-index: 2;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  align-items: flex-start;
}
@media (min-width: 768px) { .az-promo__actions { align-items: flex-end; } }

.az-promo__coupon {
  display: flex;
  align-items: center;
  gap: .75rem;
  background: rgba(255,255,255,.08);
  border: 1.5px dashed rgba(135,96,44,.5);
  border-radius: .875rem;
  padding: .75rem 1.25rem;
}
.az-promo__coupon-label {
  font-size: .75rem;
  color: rgba(255,255,255,.6);
}
.az-promo__coupon-code {
  font-size: 1.1rem;
  font-weight: 900;
  color: var(--az-gold);
  letter-spacing: .1em;
}

/* ================================================================
   6. TESTIMONIALS
   ================================================================ */
.az-testimonials { background: var(--az-gray-lt); }

.az-testimonials__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.25rem;
}
@media (min-width: 768px) { .az-testimonials__grid { grid-template-columns: repeat(3, 1fr); } }

.az-testimonial-card {
  background: var(--az-white);
  border-radius: var(--az-radius);
  padding: 2rem;
  box-shadow: var(--az-shadow);
  border: 1.5px solid transparent;
  transition: var(--az-transition);
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}
.az-testimonial-card:hover {
  border-color: rgba(135,96,44,.2);
  transform: translateY(-5px);
  box-shadow: var(--az-shadow-lg);
}

.az-testimonial-card__quote {
  font-size: 2.5rem;
  color: var(--az-gold);
  opacity: .3;
  line-height: 1;
  font-family: Georgia, serif;
}
.az-testimonial-card__stars {
  display: flex;
  gap: .2rem;
}
.az-testimonial-card__text {
  font-size: .95rem;
  color: #4b5563;
  line-height: 1.8;
  flex: 1;
}
.az-testimonial-card__author {
  display: flex;
  align-items: center;
  gap: .875rem;
  padding-top: 1rem;
  border-top: 1px solid var(--az-gray-lt);
}
.az-testimonial-card__avatar {
  width: 3rem; height: 3rem;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--az-dark), var(--az-gold));
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-weight: 900;
  font-size: 1.1rem;
  flex-shrink: 0;
}
.az-testimonial-card__name {
  font-weight: 800;
  color: var(--az-dark);
  font-size: .95rem;
}
.az-testimonial-card__role {
  font-size: .78rem;
  color: var(--az-gray);
}

/* ================================================================
   7. FAQ
   ================================================================ */
.az-faq { background: var(--az-white); }
.az-faq__inner { max-width: 52rem; margin: 0 auto; }

.az-faq__item {
  background: var(--az-cream);
  border-radius: 1rem;
  margin-bottom: .875rem;
  border: 1.5px solid transparent;
  overflow: hidden;
  transition: var(--az-transition);
}
.az-faq__item[open] {
  border-color: rgba(135,96,44,.2);
  box-shadow: var(--az-shadow);
}
.az-faq__item summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.4rem 1.75rem;
  cursor: pointer;
  list-style: none;
  gap: 1rem;
}
.az-faq__item summary::-webkit-details-marker { display: none; }
.az-faq__question {
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--az-dark);
  flex: 1;
  text-align: right;
}
.az-faq__icon {
  width: 2rem; height: 2rem;
  border-radius: 50%;
  background: rgba(135,96,44,.12);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--az-gold);
  font-size: 1.1rem;
  flex-shrink: 0;
  transition: transform .35s ease, background .35s ease;
}
.az-faq__item[open] .az-faq__icon {
  transform: rotate(180deg);
  background: var(--az-gold);
  color: #fff;
}
.az-faq__answer {
  padding: 0 1.75rem 1.5rem;
  color: #4b5563;
  line-height: 1.8;
  font-size: .95rem;
  text-align: right;
}

/* ================================================================
   8. NEWSLETTER / CTA BOTTOM
   ================================================================ */
.az-cta {
  background: linear-gradient(135deg, var(--az-dark) 0%, #3d3430 100%);
  padding: 5rem 1.25rem;
  text-align: center;
  position: relative;
  overflow: hidden;
}
@media (min-width: 768px)  { .az-cta { padding: 5rem 3rem; } }
@media (min-width: 1280px) { .az-cta { padding: 5rem 8rem; } }

.az-cta__glow {
  position: absolute;
  width: 600px; height: 600px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(135,96,44,.18) 0%, transparent 70%);
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
}
.az-cta__content { position: relative; z-index: 2; max-width: 40rem; margin: 0 auto; }
.az-cta__title {
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 900;
  color: #fff;
  margin-bottom: 1rem;
}
.az-cta__desc {
  color: rgba(255,255,255,.7);
  font-size: 1.05rem;
  margin-bottom: 2.5rem;
  line-height: 1.75;
}
.az-cta__btns {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  justify-content: center;
}

/* ================================================================
   MATERIAL ICONS
   ================================================================ */
.material-symbols-outlined {
  font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  vertical-align: middle;
  line-height: 1;
  display: inline-block;
}
</style>
{% endblock %}

{% block content %}
<div class="az-page">

{# ============================================================
   1. HERO
   ============================================================ #}
<section class="az-hero">
  <div class="az-hero__wrap">
    <div class="az-hero__bg"
         style="background-image: url('{{ theme.settings.get('hero_image','https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1800&q=85') }}');">
    </div>
    <div class="az-hero__overlay"></div>
    <div class="az-hero__glow"></div>

    <div class="az-hero__content">
      <div class="az-hero__eyebrow">
        <span class="az-hero__eyebrow-line"></span>
        <span class="az-hero__eyebrow-text">{{ theme.settings.get('hero_eyebrow','رواد معدات الصيد') }}</span>
      </div>

      <h1 class="az-hero__title">
        {{ theme.settings.get('hero_title','رفيقك الأمثل في كل') }}
        <span class="az-hero__title-highlight">{{ theme.settings.get('hero_highlight','مغامرة') }}</span>
      </h1>

      <p class="az-hero__desc">
        {{ theme.settings.get('hero_description','نعيد تعريف التميز في الصيد والرحلات البرية. اختبر الصحراء بمعدات فاخرة تم اختيارها بعناية من قبل خبراء.') }}
      </p>

      <div class="az-hero__btns">
        <a href="{{ store.urls.products }}" class="az-btn az-btn--primary">
          {{ 'تسوق الآن' | trans }}
          <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <a href="{{ store.urls.products }}" class="az-btn az-btn--outline">
          {{ 'اكتشف المزيد' | trans }}
        </a>
      </div>

      <div class="az-hero__stats">
        <div>
          <div class="az-hero__stat-num">+٥٠٠٠</div>
          <div class="az-hero__stat-label">{{ 'عميل سعيد' | trans }}</div>
        </div>
        <div>
          <div class="az-hero__stat-num">+٢٠٠</div>
          <div class="az-hero__stat-label">{{ 'منتج احترافي' | trans }}</div>
        </div>
        <div>
          <div class="az-hero__stat-num">١٠+</div>
          <div class="az-hero__stat-label">{{ 'سنوات خبرة' | trans }}</div>
        </div>
      </div>
    </div>
  </div>
</section>

{# ============================================================
   2. FEATURES BAR
   ============================================================ #}
<section class="az-features">
  <div class="az-features__inner az-reveal">
    <div class="az-feature-item az-reveal az-reveal-delay-1">
      <div class="az-feature-item__icon-wrap">
        <span class="material-symbols-outlined az-feature-item__icon">local_shipping</span>
      </div>
      <div>
        <div class="az-feature-item__title">{{ 'شحن سريع مجاني' | trans }}</div>
        <div class="az-feature-item__desc">{{ 'لجميع المناطق فوق ٢٠٠ ر.س' | trans }}</div>
      </div>
    </div>
    <div class="az-feature-item az-reveal az-reveal-delay-2">
      <div class="az-feature-item__icon-wrap">
        <span class="material-symbols-outlined az-feature-item__icon">verified</span>
      </div>
      <div>
        <div class="az-feature-item__title">{{ 'منتجات أصلية ١٠٠٪' | trans }}</div>
        <div class="az-feature-item__desc">{{ 'علامات تجارية موثوقة ومجربة' | trans }}</div>
      </div>
    </div>
    <div class="az-feature-item az-reveal az-reveal-delay-3">
      <div class="az-feature-item__icon-wrap">
        <span class="material-symbols-outlined az-feature-item__icon">support_agent</span>
      </div>
      <div>
        <div class="az-feature-item__title">{{ 'دعم فني ٢٤/٧' | trans }}</div>
        <div class="az-feature-item__desc">{{ 'خبراء متواجدون دائماً' | trans }}</div>
      </div>
    </div>
    <div class="az-feature-item az-reveal az-reveal-delay-4">
      <div class="az-feature-item__icon-wrap">
        <span class="material-symbols-outlined az-feature-item__icon">replay</span>
      </div>
      <div>
        <div class="az-feature-item__title">{{ 'إرجاع مجاني' | trans }}</div>
        <div class="az-feature-item__desc">{{ 'خلال ١٤ يوم من الاستلام' | trans }}</div>
      </div>
    </div>
  </div>
</section>

{# ============================================================
   3. CATEGORIES
   ============================================================ #}
<section class="az-section az-categories">
  <div class="az-section-head az-reveal">
    <div>
      <div class="az-section-eyebrow">
        <span class="az-section-eyebrow__line"></span>
        <span class="az-section-eyebrow__text">{{ 'تصنيفاتنا' | trans }}</span>
      </div>
      <h2 class="az-section-title">{{ 'تسوق حسب الفئة' | trans }}</h2>
      <p class="az-section-subtitle">{{ 'معدات احترافية مصممة لاحتياجاتك' | trans }}</p>
    </div>
    <a href="{{ store.urls.categories ?? store.urls.products }}" class="az-view-all">
      {{ 'عرض الكل' | trans }}
      <span class="material-symbols-outlined" style="font-size:.9rem;">arrow_back</span>
    </a>
  </div>

  <div class="az-categories__grid">
    {% if categories is defined and categories | length > 0 %}
      {% for category in categories | slice(0, 4) %}
        <a href="{{ category.url }}" class="az-cat-card az-reveal az-reveal-delay-{{ loop.index }}">
          <div class="az-cat-card__bg"
               style="background-image: url('{{ category.image | default('https://images.unsplash.com/photo-1544551763-46a013bb70d5?w=800') }}');">
          </div>
          <div class="az-cat-card__overlay"></div>
          <div class="az-cat-card__arrow">
            <span class="material-symbols-outlined" style="font-size:1rem;">arrow_back</span>
          </div>
          <div class="az-cat-card__info">
            <div class="az-cat-card__name">{{ category.name }}</div>
            {% if category.products_count is defined %}
              <div class="az-cat-card__count">
                <span class="material-symbols-outlined" style="font-size:.8rem;">inventory_2</span>
                {{ category.products_count }}+ {{ 'منتج' | trans }}
              </div>
            {% endif %}
          </div>
        </a>
      {% endfor %}
    {% else %}
      {# Fallback placeholder #}
      {% set ph_cats = [
        {name:'معدات الصيد',    img:'https://images.unsplash.com/photo-1544551763-46a013bb70d5?w=800'},
        {name:'ملابس الصيد',    img:'https://images.unsplash.com/photo-1551698618-1dfe5d97d256?w=800'},
        {name:'معدات التخييم',  img:'https://images.unsplash.com/photo-1504280390367-361c6d9f38f4?w=800'},
        {name:'الإكسسوارات',   img:'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=800'}
      ] %}
      {% for cat in ph_cats %}
        <a href="{{ store.urls.products }}" class="az-cat-card az-reveal az-reveal-delay-{{ loop.index }}">
          <div class="az-cat-card__bg" style="background-image: url('{{ cat.img }}');"></div>
          <div class="az-cat-card__overlay"></div>
          <div class="az-cat-card__arrow">
            <span class="material-symbols-outlined" style="font-size:1rem;">arrow_back</span>
          </div>
          <div class="az-cat-card__info">
            <div class="az-cat-card__name">{{ cat.name }}</div>
          </div>
        </a>
      {% endfor %}
    {% endif %}
  </div>
</section>

{# ============================================================
   4. FLASH SALES
   ============================================================ #}
<section class="az-section az-flash">
  <div class="az-flash__head az-reveal">
    <div class="az-flash__title-wrap">
      <div class="az-flash__icon-box">
        <span class="material-symbols-outlined">bolt</span>
      </div>
      <div>
        <div class="az-section-eyebrow" style="margin-bottom:.3rem;">
          <span class="az-section-eyebrow__line"></span>
          <span class="az-section-eyebrow__text">{{ 'عروض محدودة' | trans }}</span>
        </div>
        <div class="az-section-title" style="margin:0 0 .2rem;">{{ 'عروض الفلاش' | trans }}</div>
        <div class="az-section-subtitle">{{ 'معدات فاخرة بأسعار استثنائية' | trans }}</div>
      </div>
    </div>
    <div class="az-countdown">
      <span class="az-countdown__label">{{ 'ينتهي خلال' | trans }}</span>
      <div class="az-countdown__digits">
        <div class="az-countdown__unit">
          <div class="az-countdown__num" id="az-hours">12</div>
          <div class="az-countdown__unit-lbl">{{ 'ساعة' | trans }}</div>
        </div>
        <span class="az-countdown__sep">:</span>
        <div class="az-countdown__unit">
          <div class="az-countdown__num" id="az-minutes">45</div>
          <div class="az-countdown__unit-lbl">{{ 'دقيقة' | trans }}</div>
        </div>
        <span class="az-countdown__sep">:</span>
        <div class="az-countdown__unit">
          <div class="az-countdown__num" id="az-seconds">08</div>
          <div class="az-countdown__unit-lbl">{{ 'ثانية' | trans }}</div>
        </div>
      </div>
    </div>
  </div>

  <div class="az-products-grid">
    {% if products is defined and products | length > 0 %}
      {% for product in products | slice(0, 4) %}
        <div class="az-product-card az-reveal az-reveal-delay-{{ loop.index }}">
          <div class="az-product-card__img-wrap">
            <a href="{{ product.url }}">
              <img class="az-product-card__img"
                   src="{{ product.thumbnail | default(product.image) }}"
                   alt="{{ product.name }}"
                   loading="lazy" />
            </a>
            {% if product.discount_percent is defined and product.discount_percent %}
              <span class="az-product-card__badge">{{ 'وفر' | trans }} {{ product.discount_percent }}٪</span>
            {% endif %}
            <div class="az-product-card__wishlist">
              <span class="material-symbols-outlined" style="font-size:1.1rem;">favorite</span>
            </div>
          </div>
          <div class="az-product-card__body">
            <div class="az-product-card__name">{{ product.name }}</div>
            <div class="az-product-card__stars">
              {% for i in 1..5 %}
                <span class="material-symbols-outlined az-product-card__star"
                      style="font-variation-settings:'FILL' 1;">star</span>
              {% endfor %}
              <span class="az-product-card__reviews">({{ product.reviews_count | default(0) }})</span>
            </div>
            <div class="az-product-card__price-row">
              <span class="az-product-card__price">{{ product.price | price }}</span>
              {% if product.sale_price is defined and product.sale_price %}
                <span class="az-product-card__old-price">{{ product.sale_price | price }}</span>
              {% endif %}
            </div>
            <salla-add-product-button product-id="{{ product.id }}" product-status="{{ product.status }}">
              <button class="az-product-card__add">
                <span class="material-symbols-outlined" style="font-size:1.2rem;">shopping_cart</span>
                {{ 'أضف للسلة' | trans }}
              </button>
            </salla-add-product-button>
          </div>
        </div>
      {% endfor %}
    {% else %}
      {% for i in 1..4 %}
        <div class="az-product-card az-reveal az-reveal-delay-{{ i }}">
          <div class="az-product-card__img-wrap"
               style="background: linear-gradient(135deg, var(--az-dark), var(--az-gold));">
          </div>
          <div class="az-product-card__body">
            <div class="az-product-card__name">{{ 'منتج احترافي' | trans }} {{ i }}</div>
            <div class="az-product-card__stars">
              {% for j in 1..5 %}
                <span class="material-symbols-outlined az-product-card__star"
                      style="font-variation-settings:'FILL' 1;">star</span>
              {% endfor %}
            </div>
            <div class="az-product-card__price-row">
              <span class="az-product-card__price">٢٩٩ ر.س</span>
              <span class="az-product-card__old-price">٣٩٩ ر.س</span>
            </div>
            <button class="az-product-card__add">
              <span class="material-symbols-outlined" style="font-size:1.2rem;">shopping_cart</span>
              {{ 'أضف للسلة' | trans }}
            </button>
          </div>
        </div>
      {% endfor %}
    {% endif %}
  </div>
</section>

{# ============================================================
   5. PROMO BANNER
   ============================================================ #}
<section class="az-section az-promo">
  <div class="az-promo__inner az-reveal">
    <div class="az-promo__circle az-promo__circle--1"></div>
    <div class="az-promo__circle az-promo__circle--2"></div>

    <div class="az-promo__content">
      <div class="az-promo__badge">
        <span class="material-symbols-outlined" style="font-size:.9rem;">local_offer</span>
        {{ 'عرض حصري' | trans }}
      </div>
      <h2 class="az-promo__title">
        {{ 'احصل على' | trans }}
        <span class="az-promo__highlight">{{ '٢٠٪ خصم' | trans }}</span>
        <br>{{ 'على أول طلب لك' | trans }}
      </h2>
      <p class="az-promo__desc">
        {{ 'سجّل الآن واحصل على عرض ترحيبي حصري. معدات الصيد الاحترافية بأفضل الأسعار في المملكة.' | trans }}
      </p>
    </div>

    <div class="az-promo__actions">
      <div class="az-promo__coupon">
        <div>
          <div class="az-promo__coupon-label">{{ 'كود الخصم' | trans }}</div>
          <div class="az-promo__coupon-code">AZDAHAR20</div>
        </div>
        <span class="material-symbols-outlined" style="color:var(--az-gold); font-size:1.3rem;">content_copy</span>
      </div>
      <a href="{{ store.urls.products }}" class="az-btn az-btn--primary" style="font-size:1.05rem; padding:1.1rem 2.5rem;">
        {{ 'تسوق الآن' | trans }}
        <span class="material-symbols-outlined">arrow_back</span>
      </a>
    </div>
  </div>
</section>

{# ============================================================
   6. TESTIMONIALS
   ============================================================ #}
<section class="az-section az-testimonials">
  <div class="az-section-head az-reveal">
    <div>
      <div class="az-section-eyebrow">
        <span class="az-section-eyebrow__line"></span>
        <span class="az-section-eyebrow__text">{{ 'آراء العملاء' | trans }}</span>
      </div>
      <h2 class="az-section-title">{{ 'ماذا يقول عملاؤنا' | trans }}</h2>
      <p class="az-section-subtitle">{{ 'آراء حقيقية من صيادين محترفين' | trans }}</p>
    </div>
  </div>

  <div class="az-testimonials__grid">
    {% set testimonials = [
      {name:'أحمد الغامدي',  role:'صياد محترف',  initial:'أ',
       text:'أفضل معدات صيد اشتريتها في حياتي. الجودة ممتازة والتوصيل كان سريعاً جداً. أنصح الجميع بالتسوق من هنا.'},
      {name:'محمد العتيبي',  role:'مغامر برّي',   initial:'م',
       text:'تجربة تسوق رائعة! المنتجات أصلية ١٠٠٪ والأسعار منافسة. خدمة العملاء ممتازة وتجاوبت معي بسرعة.'},
      {name:'خالد الدوسري',  role:'هاوي رحلات',  initial:'خ',
       text:'المعدات التي اشتريتها غيّرت تجربة الصيد لديّ كلياً. جودة عالية وتصميم احترافي. سأعود للشراء مجدداً.'}
    ] %}
    {% for t in testimonials %}
      <div class="az-testimonial-card az-reveal az-reveal-delay-{{ loop.index }}">
        <div class="az-testimonial-card__quote">"</div>
        <div class="az-testimonial-card__stars">
          {% for i in 1..5 %}
            <span class="material-symbols-outlined"
                  style="font-size:.95rem; color:var(--az-gold); font-variation-settings:'FILL' 1;">star</span>
          {% endfor %}
        </div>
        <p class="az-testimonial-card__text">{{ t.text }}</p>
        <div class="az-testimonial-card__author">
          <div class="az-testimonial-card__avatar">{{ t.initial }}</div>
          <div>
            <div class="az-testimonial-card__name">{{ t.name }}</div>
            <div class="az-testimonial-card__role">{{ t.role }}</div>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
</section>

