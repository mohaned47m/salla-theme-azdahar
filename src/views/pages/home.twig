{% extends 'layouts/main.twig' %}

{% block title %}{{ store.name }} - متجر معدات الصيد والرحلات الاحترافية{% endblock %}

{% block content %}
    <!-- Hero Section -->
    <section class="p-4 md:p-10 lg:px-40">
        <div class="relative min-h-[580px] rounded-3xl overflow-hidden flex flex-col justify-center p-8 md:p-20 group" 
             style="background-image: linear-gradient(270deg, rgba(47, 40, 36, 0.9) 0%, rgba(47, 40, 36, 0.4) 60%, rgba(47, 40, 36, 0) 100%), url('https://lh3.googleusercontent.com/aida-public/AB6AXuDQafXGC-tH1Xwqoz6lTROyU7ilkmIWOYQqw9QWXWIAvhrgEfQnSsQzSoQKtstL1Aix-PN2OYg4Pp_xS0jzQ-Rhyxg1hLwnLSrREm5BgVQ6ihhxuH1JWA2eW9arlv6j8NIsSEyO33FVCGdgWQsoS3k7cnvv238YwuPeIn4Naz5cWD7W2HqFw4fBbcvbIDWUj-mkIaxGFe_KFwEFrGMFD4C5dFSQSX9wADNVhKJebPSEJVrRIfKPlFNwGuYBgkvGaNMMWXFx17pmBck'); background-size: cover; background-position: center;">
            <div class="relative z-10 max-w-xl">
                <div class="flex items-center gap-2 mb-6">
                    <span class="w-10 h-[2px]" style="background-color: var(--brand-secondary);"></span>
                    <span class="text-sm font-black tracking-widest uppercase" style="color: var(--brand-secondary);">رواد معدات الصيد</span>
                </div>
                <h2 class="text-5xl md:text-7xl font-black text-white leading-[1.2] mb-8">
                    رفيقك الأمثل في كل <span style="color: var(--brand-secondary);">مغامرة</span>
                </h2>
                <p class="text-slate-200 text-lg mb-10 leading-relaxed font-medium">
                    نعيد تعريف التميز في الصيد والرحلات البرية. اختبر الصحراء بمعدات فاخرة تم اختيارها بعناية من قبل خبراء يمتلكون 10 سنوات من الخبرة.
                </p>
                <div class="flex flex-wrap gap-5">
                    <button class="px-10 py-5 text-white font-black rounded-xl hover:shadow-lg transition-all flex items-center gap-3 transform hover:-translate-y-1" 
                            style="background-color: var(--brand-secondary);">
                        تسوق الأكثر مبيعاً
                        <span class="material-symbols-outlined font-bold">arrow_back</span>
                    </button>
                    <button class="px-10 py-5 bg-white text-brand-dark font-black rounded-xl border-2 border-transparent hover:border-brand-secondary transition-all transform hover:-translate-y-1">
                        وصلنا حديثاً
                    </button>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section class="px-4 md:px-10 lg:px-40 py-12">
        <div class="bg-slate-50 border border-slate-100 rounded-2xl p-10">
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8">
                <div class="flex flex-row items-center gap-4">
                    <span class="material-symbols-outlined text-5xl" style="color: var(--brand-secondary);">history_edu</span>
                    <div class="text-right">
                        <h4 class="font-bold text-brand-dark text-lg">خبرة ١٠ سنوات</h4>
                        <p class="text-sm text-slate-500">رواد في المجال منذ عام ٢٠١٤</p>
                    </div>
                </div>
                <div class="flex flex-row items-center gap-4">
                    <span class="material-symbols-outlined text-5xl" style="color: var(--brand-secondary);">local_shipping</span>
                    <div class="text-right">
                        <h4 class="font-bold text-brand-dark text-lg">شحن سريع</h4>
                        <p class="text-sm text-slate-500">توصيل موثوق لجميع المناطق</p>
                    </div>
                </div>
                <div class="flex flex-row items-center gap-4">
                    <span class="material-symbols-outlined text-5xl" style="color: var(--brand-secondary);">verified</span>
                    <div class="text-right">
                        <h4 class="font-bold text-brand-dark text-lg">منتجات أصلية</h4>
                        <p class="text-sm text-slate-500">علامات تجارية موثوقة ومجربة</p>
                    </div>
                </div>
                <div class="flex flex-row items-center gap-4">
                    <span class="material-symbols-outlined text-5xl" style="color: var(--brand-secondary);">support_agent</span>
                    <div class="text-right">
                        <h4 class="font-bold text-brand-dark text-lg">دعم فني متخصص</h4>
                        <p class="text-sm text-slate-500">متواجدون دائماً لمساعدتك</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Categories Section -->
    <section class="px-4 md:px-10 lg:px-40 py-16">
        <div class="flex items-end justify-between mb-12">
            <div>
                <h3 class="text-3xl font-black text-brand-dark mb-2">تسوق حسب الفئة</h3>
                <p class="text-slate-500 font-medium">معدات احترافية مصممة لاحتياجاتك الخاصة</p>
            </div>
            <a class="text-sm font-bold flex items-center gap-2 group" style="color: var(--brand-secondary);" href="#">
                عرض الكل 
                <span class="material-symbols-outlined text-sm transition-transform group-hover:-translate-x-1">arrow_back</span>
            </a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
            {% for category in categories | slice(0, 4) %}
            <div class="group relative aspect-[4/5] overflow-hidden rounded-2xl cursor-pointer">
                <div class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-110" 
                     style="background-image: linear-gradient(0deg, rgba(47, 40, 36, 0.8) 0%, rgba(47, 40, 36, 0.1) 100%), url('{{ category.image }}');"></div>
                <div class="absolute bottom-6 right-6 left-6">
                    <h4 class="text-xl font-black text-white mb-1">{{ category.name }}</h4>
                    <span class="text-xs font-bold bg-white/10 backdrop-blur-md px-2 py-1 rounded" style="color: var(--brand-secondary);">{{ category.products_count }}+ منتج</span>
                </div>
            </div>
            {% endfor %}
        </div>
    </section>

    <!-- Products Section -->
    <section class="px-4 md:px-10 lg:px-40 py-16">
        <div class="flex items-center justify-between mb-12">
            <div>
                <h3 class="text-3xl font-black text-brand-dark mb-2">المنتجات المميزة</h3>
                <p class="text-slate-500 font-medium">أفضل المنتجات المختارة بعناية</p>
            </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            {% for product in products | slice(0, 8) %}
            <div class="bg-white rounded-2xl p-4 border border-slate-50 group transition-all hover:border-brand-secondary/30">
                <div class="relative aspect-square rounded-xl overflow-hidden bg-slate-100 mb-5">
                    <img alt="{{ product.name }}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" 
                         src="{{ product.image }}"/>
                    {% if product.discount %}
                    <span class="absolute top-3 right-3 text-white text-[10px] font-black px-3 py-1.5 rounded-full uppercase tracking-wider shadow-lg" 
                          style="background-color: var(--brand-secondary);">وفر {{ product.discount }}٪</span>
                    {% endif %}
                </div>
                <h5 class="text-brand-dark font-black mb-1 text-lg leading-tight truncate">{{ product.name }}</h5>
                <div class="flex items-center gap-1 mb-4">
                    {% for i in range(1, 6) %}
                    <span class="material-symbols-outlined text-[16px]" style="color: var(--brand-secondary); font-variation-settings: 'FILL' 1;">star</span>
                    {% endfor %}
                    <span class="text-[12px] text-slate-400 font-bold mr-1">({{ product.reviews_count | default(0) }} تقييم)</span>
                </div>
                <div class="flex items-baseline gap-2 mb-5">
                    <span class="font-black text-2xl" style="color: var(--brand-secondary);">{{ product.price | money }}</span>
                    {% if product.original_price %}
                    <span class="text-slate-400 line-through text-sm font-medium">{{ product.original_price | money }}</span>
                    {% endif %}
                </div>
                <button class="w-full py-4 text-white font-black rounded-xl hover:brightness-110 transition-all flex items-center justify-center gap-2 group/btn" 
                        style="background-color: var(--brand-dark);">
                    <span class="material-symbols-outlined text-xl transition-transform group-hover/btn:scale-110">shopping_cart</span>
                    أضف للسلة
                </button>
            </div>
            {% endfor %}
        </div>
    </section>
{% endblock %}
