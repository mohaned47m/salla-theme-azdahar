{#
| Variable              | Type    | Description                          |
|-----------------------|---------|--------------------------------------|
| store.name            | string  | Store name                           |
| store.description     | string  | Store description                    |
| store.logo            | string  | Store logo URL                       |
| store.social          | object  | Social media links                   |
#}

<footer class="text-white mt-auto" style="background-color: var(--brand-dark);">

    {# Newsletter Bar #}
    <div class="border-b" style="border-color: rgba(255,255,255,0.1);">
        <div class="px-4 md:px-10 lg:px-40 py-10">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-8">
                <div>
                    <h4 class="text-2xl font-black mb-2">{{ 'اشترك في نشرتنا البريدية' | trans }}</h4>
                    <p class="text-white/60 font-medium">{{ 'كن أول من يعلم بالعروض والمنتجات الجديدة' | trans }}</p>
                </div>
                <div class="flex gap-3 md:min-w-[400px]">
                    <salla-newsletter class="flex-1">
                        <div class="flex gap-3">
                            <input type="email"
                                   placeholder="{{ 'أدخل بريدك الإلكتروني' | trans }}"
                                   class="flex-1 px-5 py-3.5 rounded-xl text-sm font-medium focus:outline-none focus:ring-1 focus:border-brand-secondary border border-transparent bg-white/10 text-white placeholder-white/40 transition-all"
                                   dir="rtl">
                            <button type="submit"
                                    class="px-8 py-3.5 text-white font-black rounded-xl hover:brightness-110 transition-all whitespace-nowrap"
                                    style="background-color: var(--brand-secondary);">
                                {{ 'اشترك' | trans }}
                            </button>
                        </div>
                    </salla-newsletter>
                </div>
            </div>
        </div>
    </div>

    {# Footer Main #}
    <div class="px-4 md:px-10 lg:px-40 py-16">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">

            {# Brand Column #}
            <div class="lg:col-span-1">
                <a href="{{ store.url }}" class="inline-block mb-6">
                    {% if store.logo %}
                        <img src="{{ store.logo | cdn(175) }}" alt="{{ store.name }}" class="h-12 w-auto object-contain brightness-0 invert">
                    {% else %}
                        <span class="text-2xl font-black text-white">{{ store.name }}</span>
                    {% endif %}
                </a>
                <p class="text-white/60 text-sm leading-relaxed mb-6 font-medium">
                    {{ store.description | default('رواد معدات الصيد والرحلات الاحترافية في المملكة العربية السعودية. نقدم منتجات عالية الجودة لعشاق الطبيعة والمغامرة.') }}
                </p>
                {# Social Links #}
                <div class="flex items-center gap-3">
                    {% if store.social.twitter %}
                        <a href="{{ store.social.twitter }}" target="_blank" rel="noopener"
                           class="size-10 rounded-lg flex items-center justify-center transition-all hover:scale-110"
                           style="background-color: rgba(255,255,255,0.1);">
                            <svg class="w-5 h-5 fill-white" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                        </a>
                    {% endif %}
                    {% if store.social.instagram %}
                        <a href="{{ store.social.instagram }}" target="_blank" rel="noopener"
                           class="size-10 rounded-lg flex items-center justify-center transition-all hover:scale-110"
                           style="background-color: rgba(255,255,255,0.1);">
                            <svg class="w-5 h-5 fill-white" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                        </a>
                    {% endif %}
                    {% if store.social.snapchat %}
                        <a href="{{ store.social.snapchat }}" target="_blank" rel="noopener"
                           class="size-10 rounded-lg flex items-center justify-center transition-all hover:scale-110"
                           style="background-color: rgba(255,255,255,0.1);">
                            <svg class="w-5 h-5 fill-white" viewBox="0 0 24 24"><path d="M12.206.793c.99 0 4.347.276 5.93 3.821.529 1.193.403 3.219.299 4.847l-.003.06c-.012.18-.022.345-.03.51.075.045.203.09.401.09.3-.016.659-.12 1.033-.301.165-.088.344-.104.464-.104.182 0 .359.029.509.09.45.149.734.479.734.838.015.449-.39.839-1.213 1.168-.089.029-.209.075-.344.119-.45.135-1.139.36-1.333.81-.09.224-.061.524.12.868l.015.015c.06.136 1.526 3.475 4.791 4.014.255.044.435.27.42.509 0 .075-.015.149-.045.225-.24.569-1.273.988-3.146 1.271-.059.091-.12.375-.164.57-.029.179-.074.36-.134.553-.076.271-.27.405-.555.405h-.03c-.135 0-.313-.031-.538-.074-.36-.075-.765-.135-1.273-.135-.3 0-.599.015-.913.074-.6.104-1.123.464-1.723.884-.853.599-1.826 1.288-3.294 1.288-.06 0-.119-.015-.18-.015h-.149c-1.468 0-2.427-.675-3.279-1.288-.599-.42-1.107-.779-1.707-.884-.314-.045-.629-.074-.928-.074-.54 0-.958.089-1.272.149-.211.043-.391.074-.54.074-.374 0-.523-.224-.583-.42-.061-.192-.09-.389-.135-.567-.046-.181-.105-.494-.166-.57-1.918-.222-2.95-.642-3.189-1.226-.031-.063-.052-.15-.055-.225-.015-.243.165-.465.42-.509 3.264-.54 4.73-3.879 4.791-4.02l.016-.029c.18-.345.224-.645.119-.869-.195-.434-.884-.658-1.332-.809-.121-.029-.24-.074-.346-.119-1.107-.435-1.257-.93-1.197-1.273.09-.479.674-.793 1.168-.793.146 0 .27.029.383.074.42.194.789.3 1.104.3.234 0 .384-.06.465-.105l-.046-.569c-.098-1.626-.225-3.651.307-4.837C7.392 1.077 10.739.807 11.727.807l.419-.015h.06z"/></svg>
                        </a>
                    {% endif %}
                    {% if store.social.whatsapp %}
                        <a href="https://wa.me/{{ store.social.whatsapp }}" target="_blank" rel="noopener"
                           class="size-10 rounded-lg flex items-center justify-center transition-all hover:scale-110"
                           style="background-color: rgba(255,255,255,0.1);">
                            <svg class="w-5 h-5 fill-white" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                        </a>
                    {% endif %}
                </div>
            </div>

            {# Quick Links #}
            <div>
                <h5 class="font-black text-lg mb-6 pb-3 border-b" style="border-color: rgba(255,255,255,0.1);">{{ 'روابط سريعة' | trans }}</h5>
                <ul class="space-y-3">
                    <li><a href="{{ store.url }}" class="text-white/60 hover:text-white transition-colors font-medium text-sm flex items-center gap-2"><span class="material-symbols-outlined text-xs" style="color: var(--brand-secondary);">chevron_left</span>{{ 'الرئيسية' | trans }}</a></li>
                    <li><a href="{{ store.urls.products }}" class="text-white/60 hover:text-white transition-colors font-medium text-sm flex items-center gap-2"><span class="material-symbols-outlined text-xs" style="color: var(--brand-secondary);">chevron_left</span>{{ 'المنتجات' | trans }}</a></li>
                    <li><a href="{{ store.urls.categories ?? '#' }}" class="text-white/60 hover:text-white transition-colors font-medium text-sm flex items-center gap-2"><span class="material-symbols-outlined text-xs" style="color: var(--brand-secondary);">chevron_left</span>{{ 'الفئات' | trans }}</a></li>
                    <li><a href="{{ store.urls.offers ?? '#' }}" class="text-white/60 hover:text-white transition-colors font-medium text-sm flex items-center gap-2"><span class="material-symbols-outlined text-xs" style="color: var(--brand-secondary);">chevron_left</span>{{ 'العروض' | trans }}</a></li>
                    <li><a href="{{ store.urls.new_arrivals ?? '#' }}" class="text-white/60 hover:text-white transition-colors font-medium text-sm flex items-center gap-2"><span class="material-symbols-outlined text-xs" style="color: var(--brand-secondary);">chevron_left</span>{{ 'وصل حديثاً' | trans }}</a></li>
                </ul>
            </div>

            {# Customer Service #}
            <div>
                <h5 class="font-black text-lg mb-6 pb-3 border-b" style="border-color: rgba(255,255,255,0.1);">{{ 'خدمة العملاء' | trans }}</h5>
                <ul class="space-y-3">
                    <li><a href="{{ store.urls.contact ?? '#' }}" class="text-white/60 hover:text-white transition-colors font-medium text-sm flex items-center gap-2"><span class="material-symbols-outlined text-xs" style="color: var(--brand-secondary);">chevron_left</span>{{ 'تواصل معنا' | trans }}</a></li>
                    <li><a href="{{ store.urls.about ?? '#' }}" class="text-white/60 hover:text-white transition-colors font-medium text-sm flex items-center gap-2"><span class="material-symbols-outlined text-xs" style="color: var(--brand-secondary);">chevron_left</span>{{ 'من نحن' | trans }}</a></li>
                    <li><a href="{{ store.urls.privacy ?? '#' }}" class="text-white/60 hover:text-white transition-colors font-medium text-sm flex items-center gap-2"><span class="material-symbols-outlined text-xs" style="color: var(--brand-secondary);">chevron_left</span>{{ 'سياسة الخصوصية' | trans }}</a></li>
                    <li><a href="{{ store.urls.terms ?? '#' }}" class="text-white/60 hover:text-white transition-colors font-medium text-sm flex items-center gap-2"><span class="material-symbols-outlined text-xs" style="color: var(--brand-secondary);">chevron_left</span>{{ 'الشروط والأحكام' | trans }}</a></li>
                    <li><a href="{{ store.urls.return_policy ?? '#' }}" class="text-white/60 hover:text-white transition-colors font-medium text-sm flex items-center gap-2"><span class="material-symbols-outlined text-xs" style="color: var(--brand-secondary);">chevron_left</span>{{ 'سياسة الإرجاع' | trans }}</a></li>
                </ul>
            </div>

            {# Contact Info #}
            <div>
                <h5 class="font-black text-lg mb-6 pb-3 border-b" style="border-color: rgba(255,255,255,0.1);">{{ 'معلومات التواصل' | trans }}</h5>
                <div class="space-y-4">
                    {% if store.phone %}
                        <a href="tel:{{ store.phone }}" class="flex items-center gap-3 text-white/60 hover:text-white transition-colors">
                            <span class="material-symbols-outlined text-sm" style="color: var(--brand-secondary);">phone</span>
                            <span class="text-sm font-medium">{{ store.phone }}</span>
                        </a>
                    {% endif %}
                    {% if store.email %}
                        <a href="mailto:{{ store.email }}" class="flex items-center gap-3 text-white/60 hover:text-white transition-colors">
                            <span class="material-symbols-outlined text-sm" style="color: var(--brand-secondary);">email</span>
                            <span class="text-sm font-medium">{{ store.email }}</span>
                        </a>
                    {% endif %}
                    {% if store.address %}
                        <div class="flex items-start gap-3 text-white/60">
                            <span class="material-symbols-outlined text-sm mt-0.5" style="color: var(--brand-secondary);">location_on</span>
                            <span class="text-sm font-medium">{{ store.address }}</span>
                        </div>
                    {% endif %}
                </div>

                {# Payment Methods #}
                <div class="mt-8">
                    <p class="text-xs font-black uppercase tracking-wider text-white/40 mb-3">{{ 'طرق الدفع' | trans }}</p>
                    <salla-payments-icons></salla-payments-icons>
                </div>
            </div>
        </div>
    </div>

    {# Footer Bottom #}
    <div class="border-t px-4 md:px-10 lg:px-40 py-6 flex flex-col md:flex-row items-center justify-between gap-4" style="border-color: rgba(255,255,255,0.1);">
        <p class="text-white/40 text-sm font-medium">
            © {{ "now"|date("Y") }} {{ store.name }}. {{ 'جميع الحقوق محفوظة' | trans }}.
        </p>
        <div class="flex items-center gap-2 text-white/40 text-sm">
            <span>{{ 'مدعوم بـ' | trans }}</span>
            <a href="https://salla.sa" target="_blank" rel="noopener" class="hover:text-white transition-colors font-bold">سلة</a>
        </div>
    </div>
</footer>
