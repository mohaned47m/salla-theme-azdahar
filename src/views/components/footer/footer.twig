<footer class="store-footer" style="font-family: 'Cairo', sans-serif;">

<style>
  /* ===== فوتر ازدهار — ألوان ديناميكية من هوية المتجر ===== */
  .az-footer {
    background-color: var(--color-secondary, #2F2824);
    color: rgba(255,255,255,0.8);
    font-family: 'Cairo', sans-serif;
  }
  .az-footer a {
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    transition: color 0.2s;
  }
  .az-footer a:hover { color: #fff; }

  .az-footer-title {
    color: var(--color-primary);
    font-weight: 700;
    font-size: 1rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    font-family: 'Cairo', sans-serif;
  }

  .az-footer-logo img {
    max-height: 52px;
    object-fit: contain;
    filter: brightness(0) invert(1);
    margin-bottom: 1rem;
  }

  .az-footer-desc {
    color: rgba(255,255,255,0.6);
    font-size: 0.9rem;
    line-height: 1.8;
    margin-bottom: 1.25rem;
    max-width: 280px;
  }

  .az-footer-tax {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.5);
  }
  .az-footer-tax b {
    color: var(--color-primary);
  }

  .az-footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.08);
    padding: 1rem 0;
    font-size: 0.82rem;
    color: rgba(255,255,255,0.4);
  }

  salla-menu[source="footer"] {
    --salla-menu-color: rgba(255,255,255,0.7);
    --salla-menu-hover-color: var(--color-primary);
    --salla-menu-font-family: 'Cairo', sans-serif;
    display: block;
  }
  salla-contacts {
    --salla-contacts-color: rgba(255,255,255,0.7);
    --salla-contacts-hover-color: var(--color-primary);
  }
  salla-social {
    --salla-social-color: rgba(255,255,255,0.7);
    --salla-social-hover-color: var(--color-primary);
  }
  salla-apps-icons {
    --salla-apps-icons-color: rgba(255,255,255,0.7);
  }
  salla-payments {
    --salla-payments-filter: brightness(0) invert(0.7);
  }
  salla-trust-badges {
    --salla-trust-badges-filter: brightness(0) invert(0.7);
  }
</style>

<div class="az-footer">
  <div class="container">
    <div class="grid grid-cols-1 lg:grid-cols-6 gap-8 lg:gap-6 py-12">

      {# ===== معلومات المتجر ===== #}
      <div class="lg:col-span-2 rtl:lg:pl-16 ltr:lg:pr-16">
        <a href="{{ link('/') }}" class="az-footer-logo flex items-center mb-4">
          {% if store.logo %}
            <img src="{{ store.logo }}" alt="{{ store.name }}">
          {% else %}
            <span style="color:#fff; font-size:1.5rem; font-weight:800;">{{ store.name }}</span>
          {% endif %}
        </a>

        {% if store.description %}
          <div class="az-footer-desc">{{ store.description | raw }}</div>
        {% endif %}

        <div class="hidden lg:block mb-5">
          <salla-social class="block"></salla-social>
        </div>

        <div class="flex flex-wrap gap-4 items-end">
          <salla-trust-badges dark></salla-trust-badges>
          {% if store.settings.tax.number %}
            <div class="az-footer-tax flex items-end gap-2">
              {% if store.settings.tax.certificate %}
                <a class="load-img-onclick" data-modal-id="modal-value-tax" href="#/">
                  <img width="40" height="50" src="{{ 'images/tax.png' | cdn(70,70) }}"
                       loading="lazy" class="w-10 rounded-sm hover:opacity-80 transition-opacity"
                       alt="{{ trans('common.elements.tax_number') }}">
                </a>
              {% endif %}
              <div>
                <p class="mb-1">{{ trans('common.elements.tax_number') }}</p>
                <b>{{ store.settings.tax.number }}</b>
              </div>
            </div>
            {% if store.settings.tax.certificate %}
              <salla-modal sub-title-first
                           sub-title="{{ trans('common.elements.tax_number') }}"
                           modal-title="{{ store.settings.tax.number }}"
                           id="modal-value-tax">
                <div class="flex justify-center max-w-full">
                  <img class="w-full" loading="lazy"
                       data-src="{{ store.settings.tax.certificate }}"
                       alt="{{ store.settings.tax.number }}">
                </div>
              </salla-modal>
            {% endif %}
          {% endif %}
        </div>
      </div>

      {# ===== روابط الصفحات ===== #}
      <div>
        <h3 class="az-footer-title">{{ trans('blocks.footer.pages_links') }}</h3>
        <salla-menu source="footer"></salla-menu>
      </div>

      {# ===== تواصل معنا ===== #}
      <div>
        <h3 class="az-footer-title">
          {{ trans('blocks.footer.contact_us') | default('تواصل معنا') }}
        </h3>
        <salla-contacts></salla-contacts>
        <div class="lg:hidden mt-4">
          <salla-social></salla-social>
        </div>
      </div>

      {# ===== تطبيقات المتجر ===== #}
      {% if theme.settings.get('show_footer_app_column', true) %}
      <salla-apps-icons class="lg:col-span-2 rtl:lg:pr-16 ltr:lg:pl-16"></salla-apps-icons>
      {% endif %}

    </div>
  </div>

  {# ===== الشريط السفلي ===== #}
  <div class="az-footer-bottom">
    <div class="container md:flex items-center justify-between text-center gap-4">
      <span>{% hook copyright %}</span>
      <salla-payments></salla-payments>
    </div>
  </div>
</div>

</footer>
<span class="hidden bottom-2 rtl:pl-24 ltr:pr-24 md:grid-cols-3 opacity-40"></span>
