<footer class="store-footer" style="background-color: #2F2824; color: rgba(255,255,255,0.8);">
	<div aria-label="footer" class="store-footer__inner">
		<div class="container grid grid-col-1 lg:grid-cols-6 gap-8 lg:gap-6 py-12">
			{# معلومات المتجر #}
			<div class="lg:col-span-2 rtl:lg:pl-20 ltr:lg:pr-20">
				<a href="{{ link('/') }}" class="flex items-center m-0 mb-4">
					{% if store.logo %}
						<img src="{{ store.logo }}" alt="{{ store.name }}" class="h-12 object-contain" style="filter: brightness(0) invert(1);">
					{% else %}
						<h3 style="color: #fff; font-size: 1.5rem; font-weight: 800;">{{ store.name }}</h3>
					{% endif %}
				</a>
				{% if store.description %}
					<div class="max-w-sm leading-6 mb-6" style="color: rgba(255,255,255,0.65); font-size: 0.9rem;">
						{{ store.description|raw }}
          			</div>
				{% endif %}

				<div class="hidden lg:block mb-6">
					<salla-social class="block" style="--salla-social-color: rgba(255,255,255,0.7); --salla-social-hover-color: #87602C;"></salla-social>
				</div>

				<div class="flex gap-4">
				  {# trust badges #}
				  <salla-trust-badges dark></salla-trust-badges>
                  {# vat #}
                  {% if store.settings.tax.number %}
                    <div class="flex rtl:space-x-reverse space-x-2 items-end">
                      {% if store.settings.tax.certificate %}
                        <a class="load-img-onclick" data-modal-id="modal-value-tax" href="#/" alt="{{ store.settings.tax.number }}">
                          <img width="40" height="50" src="{{'images/tax.png' | cdn(70,70)}}" loading="lazy" class="w-10 rounded-sm hover:opacity-80 transition-opacity" alt="value added tax">
                        </a>
                      {% endif %}
                      <div>
                        <p class="text-sm mb-1" style="color: rgba(255,255,255,0.5);">{{ trans('common.elements.tax_number') }}</p>
                        <b class="text-sm" style="color: #e8c88a;">{{ store.settings.tax.number }}</b>
                      </div>
                    </div>

                    {% if store.settings.tax.certificate %}
                      <salla-modal sub-title-first sub-title="{{ trans('common.elements.tax_number') }}" modal-title="{{ store.settings.tax.number }}" id="modal-value-tax">
                        <div class="flex justify-center max-w-full">
                          <img class="w-full" loading="lazy"
                          data-src="{{ store.settings.tax.certificate }}"
                          alt="{{ store.settings.tax.number }}"/>
                        </div>
                      </salla-modal>
                    {% endif %}
                  {% endif %}
                </div>
            </div>

			{# روابط الصفحات #}
			<div>
				<h3 class="footer-title" style="color: #87602C; font-weight: 700; font-size: 1rem; margin-bottom: 1rem; border-bottom: 1px solid rgba(135,96,44,0.3); padding-bottom: 0.5rem;">
					{{ trans('blocks.footer.pages_links') }}
				</h3>
				<salla-menu source="footer" style="--salla-menu-color: rgba(255,255,255,0.7); --salla-menu-hover-color: #87602C;"></salla-menu>
			</div>

			{# معلومات التواصل #}
			<div>
				<h3 class="footer-title" style="color: #87602C; font-weight: 700; font-size: 1rem; margin-bottom: 1rem; border-bottom: 1px solid rgba(135,96,44,0.3); padding-bottom: 0.5rem;">
					{{ trans('blocks.footer.contact_us') | default('تواصل معنا') }}
				</h3>
				<salla-contacts style="--salla-contacts-color: rgba(255,255,255,0.7); --salla-contacts-hover-color: #87602C;"></salla-contacts>

				<div class="lg:hidden contact-social mt-4">
					<salla-social style="--salla-social-color: rgba(255,255,255,0.7); --salla-social-hover-color: #87602C;"></salla-social>
				</div>
			</div>

			{# تطبيقات المتجر #}
			<salla-apps-icons class="lg:col-span-2 rtl:lg:pr-20 ltr:lg:pl-20" style="--salla-apps-icons-color: rgba(255,255,255,0.7);"></salla-apps-icons>

		</div>
	</div>

	{# الشريط السفلي #}
	<div class="border-t" style="border-color: rgba(255,255,255,0.1);">
		<div class="md:flex items-center justify-between py-4 container text-center">
			<span class="text-sm" style="color: rgba(255,255,255,0.4);">{% hook copyright %}</span>
			<salla-payments style="--salla-payments-filter: brightness(0) invert(0.7);"></salla-payments>
		</div>
	</div>
</footer>

<span class="hidden bottom-2 rtl:pl-24 ltr:pr-24 md:grid-cols-3 opacity-40"></span>
