{#
| Variable                       | Type     | Description                                                    |
|--------------------------------|----------|----------------------------------------------------------------|
| component.image                | string   | Banner background image URL                                    |
| component.title                | string   | Banner title                                                   |
| component.description          | string   | Banner description                                             |
| component.button_text          | string   | CTA button text                                                |
| component.button_url           | string   | CTA button URL                                                 |
| position                       | int      | Sorting number starting from zero                              |
#}
<section class="s-block s-block--promo-banner azdahar-banner py-0" id="promo-banner-{{ position }}">
    <div class="relative overflow-hidden min-h-[400px] flex items-center">
        {# Background Image #}
        {% if component.image %}
        <div class="absolute inset-0 bg-cover bg-center bg-no-repeat"
             style="background-image: url('{{ component.image }}');"></div>
        {% endif %}

        {# Overlay #}
        <div class="absolute inset-0"
             style="background: linear-gradient(135deg, rgba(47,40,36,0.85) 0%, rgba(135,96,44,0.7) 100%);"></div>

        {# Content #}
        <div class="relative z-10 container mx-auto px-6 py-16 text-center text-white">
            {% if component.title %}
            <h2 class="text-3xl md:text-5xl font-bold mb-6 leading-tight">
                {{ component.title }}
            </h2>
            {% endif %}

            {% if component.description %}
            <p class="text-lg md:text-xl mb-8 max-w-2xl mx-auto opacity-90">
                {{ component.description }}
            </p>
            {% endif %}

            {% if component.button_text %}
            <a href="{{ component.button_url | default('#') }}"
               class="inline-block px-10 py-4 text-lg font-bold rounded-full border-2 border-white text-white hover:bg-white transition-all duration-300"
               style="hover:color: #2F2824;">
                {{ component.button_text }}
            </a>
            {% endif %}
        </div>
    </div>
</section>
