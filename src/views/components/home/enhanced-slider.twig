{#
| Variable                       | Type     | Description                                                                  |
|--------------------------------|----------|------------------------------------------------------------------------------|
| component                      | object   | Contains merchant settings for fields from twilight.json `component` section |
| component.slides[].image       | string   | Image url                                                                    |
| component.slides[].title       | ?string  |                                                                              |
| component.slides[].description | ?string  |                                                                              |
| component.slides[].url         | ?string  | CTA button link                                                              |
| component.slides               | object[] | list of slides                                                               |
| position                       | int      | Sorting number start from zero                                               |
#}
<section class="s-block s-block--hero-slider s-block--full-bg wide-placeholder"> 
    <salla-slider 
      id="main-slider-{{ position }}"
      auto-play
      static-when-single
      slider-config='{"lazy":"false","parallax":true}'
      {{ component.slides|length > 1 ? '' : 'show-controls="false"' }}
      type="fullwidth">
        <div slot="items">
            {% for slide in component.slides %}
                <div class="swiper-slide w-full min-h-[400px] lg:min-h-[580px] relative" style="background-color: #2F2824;">
                    {# صورة الخلفية #}
                    <div style="background-image: url({{ slide.image }});" 
                         class="{{ slide.without_overlay ? '' : 'overlay-bg' }} bg-cover bg-center absolute inset-0"
                         data-swiper-parallax="-100"></div>
                    
                    {# طبقة تدرج لوني إضافية #}
                    <div class="absolute inset-0" style="background: linear-gradient(to left, rgba(47,40,36,0.85) 0%, rgba(47,40,36,0.4) 50%, transparent 100%);"></div>
                    
                    {# محتوى السلايد #}
                    <div class="flex items-center container pb-16 sm:pb-0 home-slider__content relative h-full min-h-[400px] lg:min-h-[580px]">
                        <div class="w-full md:w-7/12 lg:w-5/12 text-white rtl:text-right ltr:text-left py-12">
                            {# شارة علوية #}
                            <span class="inline-block px-4 py-1 rounded-full text-sm font-medium mb-4" 
                                  style="background: rgba(135,96,44,0.3); border: 1px solid #87602C; color: #e8c88a;"
                                  data-swiper-parallax="-200">
                                {{ store.name }}
                            </span>
                            
                            {# العنوان الرئيسي #}
                            <h2 data-swiper-parallax="-500" 
                                class="text-3xl lg:text-5xl font-extrabold leading-tight mb-4"
                                style="text-shadow: 0 2px 12px rgba(0,0,0,0.5);">
                                {{ slide.title }}
                            </h2>
                            
                            {# الوصف #}
                            <p data-swiper-parallax="-300" 
                               class="text-base lg:text-lg mb-8 line-clamp-2 description"
                               style="color: rgba(255,255,255,0.85);">
                                {{ slide.description }}
                            </p>
                            
                            {# زر الاستكشاف #}
                            {% if slide.url %}
                            <a href="{{ slide.url }}" 
                               class="slider-cta-btn inline-flex items-center gap-2"
                               data-swiper-parallax="-200">
                                <span>{{ 'pages.home.explore_now' | trans | default('استكشف الآن') }}</span>
                                <i class="sicon-arrow-right rtl:rotate-180 inline-block"></i>
                            </a>
                            {% else %}
                            <a href="{{ store.url }}/shop" 
                               class="slider-cta-btn inline-flex items-center gap-2"
                               data-swiper-parallax="-200">
                                <span>{{ 'pages.home.shop_now' | trans | default('تسوق الآن') }}</span>
                                <i class="sicon-arrow-right rtl:rotate-180 inline-block"></i>
                            </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    </salla-slider>
</section>
