{#
| Variable                       | Type     | Description                                                    |
|--------------------------------|----------|----------------------------------------------------------------|
| component.title                | string   | Section title                                                  |
| component.categories           | array    | List of category objects from Salla                            |
| position                       | int      | Sorting number starting from zero                              |
#}
<section class="s-block s-block--categories-grid azdahar-categories py-16" id="categories-grid-{{ position }}"
         style="background-color: #f8f5f0;">
    <div class="container mx-auto px-6">
        {# Section Header #}
        <div class="text-center mb-12">
            <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: var(--color-secondary, #2F2824);">
                {{ component.title | default('تسوق حسب الفئة') }}
            </h2>
            <div class="w-20 h-1 mx-auto rounded-full" style="background: linear-gradient(90deg, var(--color-primary), var(--color-primary-light));"></div>
        </div>

        {# Categories Grid #}
        {% if component.categories is defined and component.categories|length > 0 %}
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
            {% for category in component.categories %}
            <a href="{{ category.url }}"
               class="azdahar-category-card group relative overflow-hidden rounded-2xl aspect-square block">
                {# Background Image #}
                <div class="absolute inset-0 bg-cover bg-center bg-no-repeat transition-transform duration-500 group-hover:scale-110"
                     style="background-image: url('{{ category.image.url | default(store.url ~ '/images/placeholder.png') }}');"></div>

                {# Overlay #}
                <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>

                {# Content #}
                <div class="absolute bottom-0 left-0 right-0 p-4 text-white text-center">
                    <h3 class="font-bold text-lg">{{ category.name }}</h3>
                    {% if category.products_count is defined %}
                    <p class="text-sm opacity-80">{{ category.products_count }} {{ 'منتج' | trans }}</p>
                    {% endif %}
                </div>

                {# Hover Effect #}
                <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                    <span class="px-6 py-2 rounded-full text-white font-bold text-sm border-2 border-white">
                        {{ 'تسوق الآن' | trans }}
                    </span>
                </div>
            </a>
            {% endfor %}
        </div>
        {% else %}
        {# Fallback - show categories from store #}
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
            {% for category in store.categories | default([]) | slice(0, 4) %}
            <a href="{{ category.url }}"
               class="azdahar-category-card group relative overflow-hidden rounded-2xl aspect-square block">
                <div class="absolute inset-0 bg-cover bg-center bg-no-repeat transition-transform duration-500 group-hover:scale-110"
                     style="background-image: url('{{ category.image.url | default('') }}');
                            background-color: var(--color-primary);"></div>
                <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
                <div class="absolute bottom-0 left-0 right-0 p-4 text-white text-center">
                    <h3 class="font-bold text-lg">{{ category.name }}</h3>
                </div>
            </a>
            {% else %}
            <div class="col-span-4 text-center py-12 text-gray-400">
                <i class="sicon-grid text-5xl mb-4 block"></i>
                <p>{{ 'لا توجد تصنيفات بعد' | trans }}</p>
            </div>
            {% endfor %}
        </div>
        {% endif %}
    </div>
</section>
