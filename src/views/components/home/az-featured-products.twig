{#
| Variable                    | Type    | Description                         |
|-----------------------------|---------|-------------------------------------|
| component.title             | string  | Section title                       |
| component.subtitle          | string  | Section subtitle                    |
| component.products          | array   | Product list from Salla             |
| component.display_all_url   | string  | "View all" URL                      |
| component.show_add_to_cart  | bool    | Show add-to-cart button             |
| component.show_wishlist     | bool    | Show wishlist button                |
| position                    | int     | Sort order                          |
#}
<section class="az-products s-block" id="az-products-{{ position }}" aria-label="قسم: المنتجات المميزة — ثيم: ازدهار">
  <style>
    .az-products {
      background: #fafaf9;
      padding: 5rem 0 4rem;
      direction: rtl;
    }
    .az-products__inner {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }
    .az-products__head {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 2.5rem;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .az-products__head-left h2 {
      font-size: clamp(1.5rem, 3vw, 2.2rem);
      font-weight: 900;
      color: #2F2824;
      margin: 0 0 0.4rem;
    }
    .az-products__head-left .az-divider {
      width: 50px; height: 4px;
      border-radius: 4px;
      background: linear-gradient(90deg, #C8963E, #87602C);
    }
    .az-products__head-left p {
      font-size: 0.95rem;
      color: #64748b;
      margin: 0.5rem 0 0;
    }
    .az-view-all-link {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      color: #C8963E;
      font-weight: 700;
      font-size: 0.9rem;
      text-decoration: none;
      transition: gap 0.3s;
    }
    .az-view-all-link:hover { gap: 0.7rem; color: #87602C; }
    /* Products grid */
    .az-prod-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.2rem;
    }
    @media(min-width:640px)  { .az-prod-grid { grid-template-columns: repeat(3, 1fr); } }
    @media(min-width:1024px) { .az-prod-grid { grid-template-columns: repeat(4, 1fr); } }

    .az-prod-card {
      background: #fff;
      border-radius: 16px;
      overflow: hidden;
      border: 1px solid #f1ece6;
      transition: transform 0.35s cubic-bezier(.25,.8,.25,1), box-shadow 0.35s;
      position: relative;
    }
    .az-prod-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 12px 36px rgba(47,40,36,0.12);
    }
    .az-prod-card__img-wrap {
      position: relative;
      aspect-ratio: 1;
      overflow: hidden;
      background: #f8f5f1;
    }
    .az-prod-card__img {
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }
    .az-prod-card:hover .az-prod-card__img { transform: scale(1.06); }
    .az-prod-card__badge {
      position: absolute;
      top: 0.8rem;
      right: 0.8rem;
      background: #ef4444;
      color: #fff;
      font-size: 0.72rem;
      font-weight: 700;
      padding: 0.2rem 0.6rem;
      border-radius: 50px;
    }
    .az-prod-card__wishlist {
      position: absolute;
      top: 0.8rem;
      left: 0.8rem;
      width: 36px; height: 36px;
      border-radius: 50%;
      background: rgba(255,255,255,0.9);
      border: none;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer;
      transition: background 0.3s, transform 0.3s;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    .az-prod-card__wishlist:hover {
      background: #fff;
      transform: scale(1.1);
    }
    .az-prod-card__wishlist i { font-size: 1rem; color: #C8963E; }
    .az-prod-card__body {
      padding: 1rem 1.1rem 1.2rem;
    }
    .az-prod-card__name {
      font-size: 0.9rem;
      font-weight: 700;
      color: #2F2824;
      margin: 0 0 0.5rem;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .az-prod-card__price-row {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      flex-wrap: wrap;
    }
    .az-prod-card__price {
      font-size: 1.05rem;
      font-weight: 900;
      color: #C8963E;
    }
    .az-prod-card__old-price {
      font-size: 0.82rem;
      color: #94a3b8;
      text-decoration: line-through;
    }
    .az-prod-card__add-btn {
      display: block;
      width: 100%;
      margin-top: 0.8rem;
      background: linear-gradient(135deg, #C8963E, #87602C);
      color: #fff;
      border: none;
      border-radius: 8px;
      padding: 0.6rem;
      font-size: 0.85rem;
      font-weight: 700;
      cursor: pointer;
      transition: opacity 0.3s, transform 0.3s;
      text-align: center;
      text-decoration: none;
    }
    .az-prod-card__add-btn:hover {
      opacity: 0.9;
      transform: translateY(-1px);
      color: #fff;
    }
    /* Empty state */
    .az-prod-empty {
      grid-column: 1/-1;
      text-align: center;
      padding: 3rem;
      color: #94a3b8;
    }
    .az-section-label {
      display: block;
      text-align: center;
      font-size: 0.7rem;
      color: #cbd5e1;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 2rem 0 0;
      font-family: monospace;
    }
  </style>

  <div class="az-products__inner">
    {# رأس القسم #}
    <div class="az-products__head">
      <div class="az-products__head-left">
        <h2>{{ component.title ?: 'المنتجات المميزة' }}</h2>
        <div class="az-divider"></div>
        {% if component.subtitle %}
          <p>{{ component.subtitle }}</p>
        {% endif %}
      </div>
      {% if component.display_all_url %}
        <a href="{{ component.display_all_url }}" class="az-view-all-link">
          عرض الكل <i class="sicon-arrow-left"></i>
        </a>
      {% endif %}
    </div>

    {# شبكة المنتجات #}
    <div class="az-prod-grid">
      {% if component.products is defined and component.products|length > 0 %}
        {% for product in component.products %}
          <div class="az-prod-card">
            <div class="az-prod-card__img-wrap">
              {% if product.image %}
                <img src="{{ product.image.url }}" alt="{{ product.name }}" class="az-prod-card__img" loading="lazy">
              {% endif %}
              {% if product.is_on_sale %}
                <span class="az-prod-card__badge">خصم</span>
              {% endif %}
              {% if component.show_wishlist is not defined or component.show_wishlist %}
                <button class="az-prod-card__wishlist" onclick="salla.wishlist.toggle('{{ product.id }}')">
                  <i class="sicon-heart"></i>
                </button>
              {% endif %}
            </div>
            <div class="az-prod-card__body">
              <h3 class="az-prod-card__name">{{ product.name }}</h3>
              <div class="az-prod-card__price-row">
                <span class="az-prod-card__price">{{ product.price.formatted }}</span>
                {% if product.is_on_sale and product.regular_price %}
                  <span class="az-prod-card__old-price">{{ product.regular_price.formatted }}</span>
                {% endif %}
              </div>
              {% if component.show_add_to_cart is not defined or component.show_add_to_cart %}
                <a href="{{ product.url }}" class="az-prod-card__add-btn">
                  <i class="sicon-shopping-bag"></i> أضف للسلة
                </a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      {% else %}
        <div class="az-prod-empty">
          <i class="sicon-tag" style="font-size:3rem;color:#e2d9d0;display:block;margin-bottom:1rem;"></i>
          <p>لم تتم إضافة منتجات مميزة بعد</p>
        </div>
      {% endif %}
    </div>
  </div>

  <span class="az-section-label">قسم: المنتجات المميزة — ثيم: ازدهار</span>
</section>
