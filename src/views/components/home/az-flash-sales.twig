{#
| Variable                    | Type       | Description                         |
|-----------------------------|------------|-------------------------------------|
| component.title             | string     | Section title                       |
| component.subtitle          | string     | Section subtitle                    |
| component.countdown_hours   | number     | Countdown duration in hours         |
| component.products          | Product[]  | Sale products from Salla            |
| position                    | int        | Sort order                          |
#}

{% set az_bg = component.section_bg_color ?: 'var(--color-secondary)' %}
{% set az_btn = component.btn_color ?: 'var(--color-primary)' %}
{% set az_title = component.title_color ?: '#fff' %}
<style>
  .az-flash-sales {
    --az-bg: {{ az_bg }};
    --az-btn: {{ az_btn }};
    --az-title: {{ az_title }};
    background: var(--az-bg) !important;
  }
  .az-flash-sales .az-section-title,
  .az-flash-sales .az-section-subtitle {
    color: var(--az-title) !important;
  }
  .az-flash-sales .az-btn,
  .az-flash-sales .az-btn-primary,
  .az-flash-sales .az-cta__btn-primary,
  .az-flash-sales .az-flash-card__btn,
  .az-flash-sales .az-prod-card__btn {
    background: var(--az-btn) !important;
    border-color: var(--az-btn) !important;
  }
  .az-flash-sales .az-btn:hover,
  .az-flash-sales .az-btn-primary:hover,
  .az-flash-sales .az-cta__btn-primary:hover,
  .az-flash-sales .az-flash-card__btn:hover,
  .az-flash-sales .az-prod-card__btn:hover {
    filter: brightness(0.88);
  }
</style>

<section class="az-flash s-block" id="az-flash-{{ position }}" aria-label="عروض الفلاش">
  <style>
    /* ── عروض الفلاش — ازدهار ── */
    .az-flash {
      background: linear-gradient(135deg, #2F2824 0%, #1a1512 100%);
      padding: 5rem 0 4rem;
      direction: rtl;
      position: relative;
      overflow: hidden;
    }
    .az-flash::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        repeating-linear-gradient(
          -45deg,
          transparent,
          transparent 40px,
          color-mix(in srgb, var(--color-primary) 3%, transparent) 40px,
          color-mix(in srgb, var(--color-primary) 3%, transparent) 41px
        );
      pointer-events: none;
    }
    .az-flash__inner {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 1.5rem;
      position: relative;
      z-index: 1;
    }
    /* رأس القسم */
    .az-flash__head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 2.5rem;
      flex-wrap: wrap;
      gap: 1.5rem;
    }
    .az-flash__head-left h2 {
      font-size: clamp(1.5rem, 3vw, 2.2rem);
      font-weight: 900;
      color: #fff;
      margin: 0 0 0.4rem;
    }
    .az-flash__head-left p {
      font-size: 0.9rem;
      color: rgba(255,255,255,0.6);
      margin: 0;
    }
    /* عداد تنازلي */
    .az-countdown {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .az-countdown__unit {
      text-align: center;
      background: color-mix(in srgb, var(--color-primary) 12%, transparent);
      border: 1px solid color-mix(in srgb, var(--color-primary) 30%, transparent);
      border-radius: 10px;
      padding: 0.5rem 0.9rem;
      min-width: 58px;
      transition: background 0.3s;
    }
    .az-countdown__unit:hover { background: color-mix(in srgb, var(--color-primary) 20%, transparent); }
    .az-countdown__num {
      font-size: 1.6rem;
      font-weight: 900;
      color: var(--color-primary, var(--color-primary));
      display: block;
      font-variant-numeric: tabular-nums;
      line-height: 1;
    }
    .az-countdown__label {
      font-size: 0.62rem;
      color: rgba(255,255,255,0.5);
      margin-top: 0.25rem;
    }
    .az-countdown__sep {
      font-size: 1.4rem;
      font-weight: 900;
      color: var(--color-primary, var(--color-primary));
      margin-bottom: 0.8rem;
      animation: azBlink 1s step-end infinite;
    }
    @keyframes azBlink {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0.3; }
    }
    /* شبكة المنتجات */
    .az-flash__grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.2rem;
    }
    @media (min-width: 640px)  { .az-flash__grid { grid-template-columns: repeat(3, 1fr); gap: 1.4rem; } }
    @media (min-width: 1024px) { .az-flash__grid { grid-template-columns: repeat(4, 1fr); gap: 1.6rem; } }
    /* كارد الفلاش */
    .az-flash-card {
      background: rgba(255,255,255,0.05);
      border: 1px solid color-mix(in srgb, var(--color-primary) 15%, transparent);
      border-radius: 16px;
      overflow: hidden;
      position: relative;
      display: flex;
      flex-direction: column;
      transition: transform 0.35s cubic-bezier(.25,.8,.25,1), border-color 0.35s, box-shadow 0.35s;
      animation: azFlashCardIn 0.5s ease both;
    }
    .az-flash-card:nth-child(1) { animation-delay: 0.05s; }
    .az-flash-card:nth-child(2) { animation-delay: 0.10s; }
    .az-flash-card:nth-child(3) { animation-delay: 0.15s; }
    .az-flash-card:nth-child(4) { animation-delay: 0.20s; }
    .az-flash-card:nth-child(5) { animation-delay: 0.25s; }
    .az-flash-card:nth-child(6) { animation-delay: 0.30s; }
    .az-flash-card:nth-child(7) { animation-delay: 0.35s; }
    .az-flash-card:nth-child(8) { animation-delay: 0.40s; }
    @keyframes azFlashCardIn {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .az-flash-card:hover {
      transform: translateY(-8px);
      border-color: color-mix(in srgb, var(--color-primary, var(--color-primary)) 50%, transparent);
      box-shadow: 0 16px 40px rgba(0,0,0,0.35), 0 0 0 1px color-mix(in srgb, var(--color-primary, var(--color-primary)) 20%, transparent);
    }
    /* صورة المنتج — نسبة 1:1 ثابتة */
    .az-flash-card__img-wrap {
      position: relative;
      width: 100%;
      padding-top: 100%;
      overflow: hidden;
      background: rgba(255,255,255,0.04);
      flex-shrink: 0;
    }
    .az-flash-card__img-wrap > a {
      position: absolute;
      inset: 0;
      display: block;
    }
    /* الصورة الأساسية والثانوية */
    .az-flash-card__img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
      transition: opacity 0.45s ease, transform 0.55s cubic-bezier(.25,.8,.25,1);
    }
    .az-flash-card__img--primary   { opacity: 1; z-index: 1; }
    .az-flash-card__img--secondary { opacity: 0; z-index: 2; transform: scale(1.04); }
    .az-flash-card:hover .az-flash-card__img--primary   { opacity: 0; transform: scale(1.04); }
    .az-flash-card:hover .az-flash-card__img--secondary { opacity: 1; transform: scale(1); }
    .az-flash-card.no-second-img:hover .az-flash-card__img--primary { opacity: 1; transform: scale(1.07); }
    /* بادج الخصم */
    .az-flash-card__badge {
      position: absolute;
      top: 0.75rem;
      right: 0.75rem;
      background: linear-gradient(135deg, #ef4444, #dc2626);
      color: #fff;
      font-size: 0.7rem;
      font-weight: 800;
      padding: 0.25rem 0.65rem;
      border-radius: 50px;
      box-shadow: 0 2px 8px rgba(239,68,68,0.5);
      z-index: 3;
      white-space: nowrap;
    }
    /* تراكب عرض سريع */
    .az-flash-card__overlay {
      position: absolute;
      inset: 0;
      background: color-mix(in srgb, var(--color-secondary) 35%, transparent);
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity 0.35s ease;
      z-index: 4;
    }
    .az-flash-card:hover .az-flash-card__overlay { opacity: 1; }
    .az-flash-card__quick-view {
      background: rgba(255,255,255,0.95);
      color: var(--color-secondary);
      font-size: 0.82rem;
      font-weight: 700;
      padding: 0.55rem 1.2rem;
      border-radius: 50px;
      text-decoration: none;
      transform: translateY(10px);
      transition: transform 0.35s ease, background 0.3s, color 0.3s;
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }
    .az-flash-card:hover .az-flash-card__quick-view { transform: translateY(0); }
    .az-flash-card__quick-view:hover { background: var(--color-primary, var(--color-primary)); color: #fff; }
    /* جسم الكارد */
    .az-flash-card__body {
      padding: 0.9rem 1rem 1rem;
      display: flex;
      flex-direction: column;
      flex: 1;
      gap: 0.5rem;
    }
    .az-flash-card__name {
      font-size: 0.88rem;
      font-weight: 700;
      color: #fff;
      margin: 0;
      line-height: 1.4;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      text-decoration: none;
      transition: color 0.3s;
    }
    .az-flash-card__name:hover { color: var(--color-primary, var(--color-primary)); }
    .az-flash-card__prices {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin-top: auto;
    }
    .az-flash-card__price {
      font-size: 1rem;
      font-weight: 900;
      color: var(--color-primary, var(--color-primary));
      direction: ltr;
    }
    .az-flash-card__old {
      font-size: 0.78rem;
      color: rgba(255,255,255,0.4);
      text-decoration: line-through;
      direction: ltr;
    }
    /* زر إضافة للسلة — لون identity المتجر */
    .az-flash-card__btn {
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      gap: 0.4rem !important;
      width: 100% !important;
      background: var(--color-primary, var(--color-primary)) !important;
      color: var(--color-primary-reverse, #fff) !important;
      border: none !important;
      border-radius: 10px !important;
      padding: 0.65rem 1rem !important;
      font-size: 0.85rem !important;
      font-weight: 700 !important;
      cursor: pointer !important;
      transition: opacity 0.3s, transform 0.3s, box-shadow 0.3s !important;
      text-align: center !important;
      text-decoration: none !important;
      box-shadow: 0 3px 12px color-mix(in srgb, var(--color-primary, var(--color-primary)) 35%, transparent) !important;
    }
    .az-flash-card__btn:hover {
      background: var(--color-primary-dark, var(--color-primary, var(--color-primary))) !important;
      transform: translateY(-2px) !important;
      box-shadow: 0 6px 20px color-mix(in srgb, var(--color-primary, var(--color-primary)) 50%, transparent) !important;
      color: var(--color-primary-reverse, #fff) !important;
    }
    .az-flash-card__btn i { font-size: 0.9rem; }
    /* موبايل */
    @media (max-width: 480px) {
      .az-flash { padding: 3rem 0 2.5rem; }
      .az-flash__grid { gap: 0.75rem; }
      .az-flash__head { flex-direction: column; align-items: flex-start; }
      .az-flash-card__body { padding: 0.7rem 0.75rem 0.8rem; }
      .az-flash-card__name { font-size: 0.8rem; }
      .az-flash-card__price { font-size: 0.9rem; }
      .az-flash-card__btn { font-size: 0.78rem !important; padding: 0.55rem !important; }
      .az-countdown__num { font-size: 1.2rem; }
    }
  </style>

  <div class="az-flash__inner">
    {# رأس القسم #}
    <div class="az-flash__head">
      <div class="az-flash__head-left">
        <h2>{{ component.title ?: '⚡ عروض الفلاش الحصرية' }}</h2>
        <p>{{ component.subtitle ?: 'عروض محدودة الوقت — لا تفوّتها!' }}</p>
      </div>
      {# عداد تنازلي #}
      <div class="az-countdown" id="az-countdown-{{ position }}">
        <div class="az-countdown__unit">
          <span class="az-countdown__num" id="az-h-{{ position }}">00</span>
          <div class="az-countdown__label">ساعة</div>
        </div>
        <span class="az-countdown__sep">:</span>
        <div class="az-countdown__unit">
          <span class="az-countdown__num" id="az-m-{{ position }}">00</span>
          <div class="az-countdown__label">دقيقة</div>
        </div>
        <span class="az-countdown__sep">:</span>
        <div class="az-countdown__unit">
          <span class="az-countdown__num" id="az-s-{{ position }}">00</span>
          <div class="az-countdown__label">ثانية</div>
        </div>
      </div>
    </div>

    {% if component.products is defined and component.products|length > 0 %}
      <div class="az-flash__grid">
        {% for product in component.products %}
          {# حساب نسبة الخصم الحقيقية #}
          {% set discount_pct = 0 %}
          {% if product.sale_price is defined and product.sale_price and product.price %}
            {% set discount_pct = ((product.price - product.sale_price) / product.price * 100) | round %}
          {% elseif product.regular_price is defined and product.regular_price and product.price %}
            {% set discount_pct = ((product.regular_price - product.price) / product.regular_price * 100) | round %}
          {% endif %}

          {# الصورة الثانية للهوفر #}
          {% set second_img = '' %}
          {% if product.images is defined and product.images|length > 1 %}
            {% set second_img = product.images[1].url %}
          {% endif %}

          <div class="az-flash-card{% if not second_img %} no-second-img{% endif %}">
            <div class="az-flash-card__img-wrap">
              <a href="{{ product.url }}">
                {# الصورة الأساسية #}
                <img
                  src="{{ product.thumbnail.url | default(product.image.url | default('')) }}"
                  alt="{{ product.name }}"
                  class="az-flash-card__img az-flash-card__img--primary"
                  loading="lazy">
                {# الصورة الثانية — تظهر عند الهوفر #}
                {% if second_img %}
                  <img
                    src="{{ second_img }}"
                    alt="{{ product.name }}"
                    class="az-flash-card__img az-flash-card__img--secondary"
                    loading="lazy">
                {% endif %}
              </a>
              {# بادج الخصم بنسبة مئوية حقيقية #}
              {% if product.is_on_sale and discount_pct > 0 %}
                <span class="az-flash-card__badge">{{ discount_pct }}% خصم</span>
              {% elseif product.is_on_sale %}
                <span class="az-flash-card__badge">خصم</span>
              {% endif %}
              <div class="az-flash-card__overlay">
                <a href="{{ product.url }}" class="az-flash-card__quick-view">
                  <i class="sicon-eye"></i> عرض المنتج
                </a>
              </div>
            </div>
            <div class="az-flash-card__body">
              <a href="{{ product.url }}" class="az-flash-card__name">{{ product.name }}</a>
              <div class="az-flash-card__prices">
                <span class="az-flash-card__price">
                  {{ (product.sale_price ?: product.price) | money }}
                </span>
                {% if product.is_on_sale and product.price %}
                  <span class="az-flash-card__old">{{ product.price | money }}</span>
                {% endif %}
              </div>
              <salla-add-product-button product-id="{{ product.id }}" class="az-flash-card__btn">
                <i class="sicon-shopping-bag"></i> {{ trans('pages.cart.add_to_cart') }}
              </salla-add-product-button>
            </div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      {# Fallback: مكون سلة الرسمي #}
      <salla-products-slider
        source="sale"
        limit="8"
        block-title=" "
        slider-id="az-flash-slider-{{ position }}"
      ></salla-products-slider>
    {% endif %}
  </div>

  <script>
    (function() {
      var hours = {{ component.countdown_hours ?: 12 }};
      var end = new Date().getTime() + hours * 3600 * 1000;
      var pos = '{{ position }}';
      function tick() {
        var now = new Date().getTime();
        var diff = Math.max(0, end - now);
        var h = Math.floor(diff / 3600000);
        var m = Math.floor((diff % 3600000) / 60000);
        var s = Math.floor((diff % 60000) / 1000);
        var pad = function(n){ return n < 10 ? '0'+n : n; };
        var eh = document.getElementById('az-h-'+pos);
        var em = document.getElementById('az-m-'+pos);
        var es = document.getElementById('az-s-'+pos);
        if(eh) eh.textContent = pad(h);
        if(em) em.textContent = pad(m);
        if(es) es.textContent = pad(s);
        if(diff > 0) setTimeout(tick, 1000);
      }
      tick();
    })();
  </script>
</section>
