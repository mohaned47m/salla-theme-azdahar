{#
| Variable                | Type       | Description                     |
|-------------------------|------------|---------------------------------|
| component.title         | string     | Section title                   |
| component.subtitle      | string     | Section subtitle                |
| component.show_view_all | bool       | Show "view all" button          |
| component.categories    | Category[] | Store categories from Salla     |
| position                | int        | Sort order                      |
#}
<section class="az-categories s-block" id="az-categories-{{ position }}" >
  <style>
    .az-categories {
      background: #fff;
      padding: 5rem 0 4rem;
      direction: rtl;
    }
    .az-categories__inner {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }
    .az-section-head {
      text-align: center;
      margin-bottom: 3rem;
    }
    .az-section-head__eyebrow {
      display: inline-block;
      font-size: 0.8rem;
      font-weight: 700;
      color: #C8963E;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 0.6rem;
    }
    .az-section-head__title {
      font-size: clamp(1.6rem, 3vw, 2.4rem);
      font-weight: 900;
      color: #2F2824;
      margin: 0 0 0.6rem;
    }
    .az-section-head__divider {
      width: 60px; height: 4px;
      border-radius: 4px;
      background: linear-gradient(90deg, #C8963E, #87602C);
      margin: 0.8rem auto 0;
    }
    .az-section-head__sub {
      font-size: 1rem;
      color: #64748b;
      margin-top: 0.8rem;
    }
    /* Grid */
    .az-cat-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.2rem;
    }
    @media(min-width:640px)  { .az-cat-grid { grid-template-columns: repeat(3, 1fr); } }
    @media(min-width:1024px) { .az-cat-grid { grid-template-columns: repeat(4, 1fr); } }

    .az-cat-card {
      position: relative;
      border-radius: 16px;
      overflow: hidden;
      aspect-ratio: 3/4;
      display: block;
      text-decoration: none;
      background: #f1ece6;
      box-shadow: 0 2px 12px rgba(47,40,36,0.08);
      transition: transform 0.4s cubic-bezier(.25,.8,.25,1), box-shadow 0.4s;
    }
    .az-cat-card:hover {
      transform: translateY(-8px) scale(1.01);
      box-shadow: 0 16px 40px rgba(47,40,36,0.18);
    }
    .az-cat-card__img {
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.6s ease;
    }
    .az-cat-card:hover .az-cat-card__img {
      transform: scale(1.08);
    }
    .az-cat-card__placeholder {
      width: 100%; height: 100%;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      gap: 0.8rem;
      background: linear-gradient(135deg, #f1ece6, #e8ddd4);
    }
    .az-cat-card__placeholder i {
      font-size: 2.5rem;
      color: #C8963E;
      opacity: 0.6;
    }
    .az-cat-card__overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(26,21,18,0.85) 0%, rgba(26,21,18,0.2) 50%, transparent 100%);
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 1.5rem 1.2rem;
      transition: background 0.3s;
    }
    .az-cat-card:hover .az-cat-card__overlay {
      background: linear-gradient(to top, rgba(26,21,18,0.92) 0%, rgba(26,21,18,0.35) 60%, rgba(26,21,18,0.05) 100%);
    }
    .az-cat-card__name {
      font-size: 1.05rem;
      font-weight: 800;
      color: #fff;
      margin: 0 0 0.3rem;
      text-shadow: 0 1px 6px rgba(0,0,0,0.4);
    }
    .az-cat-card__arrow {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      font-size: 0.8rem;
      color: #C8963E;
      font-weight: 600;
      opacity: 0;
      transform: translateX(8px);
      transition: opacity 0.3s, transform 0.3s;
    }
    .az-cat-card:hover .az-cat-card__arrow {
      opacity: 1;
      transform: none;
    }
    /* Empty state */
    .az-cat-empty {
      grid-column: 1/-1;
      text-align: center;
      padding: 3rem;
      color: #94a3b8;
      font-size: 0.95rem;
    }
    /* View All */
    .az-view-all-wrap {
      text-align: center;
      margin-top: 2.5rem;
    }
    .az-btn-outline {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      border: 2px solid #C8963E;
      color: #C8963E;
      padding: 0.8rem 2rem;
      border-radius: 50px;
      font-size: 0.95rem;
      font-weight: 700;
      text-decoration: none;
      transition: background 0.3s, color 0.3s, transform 0.3s;
    }
    .az-btn-outline:hover {
      background: #C8963E;
      color: #fff;
      transform: translateY(-2px);
    }
  </style>

  <div class="az-categories__inner">
    {# رأس القسم #}
    <div class="az-section-head">
      <span class="az-section-head__eyebrow">{{ trans('common.categories') }}</span>
      <h2 class="az-section-head__title">{{ component.title ?: trans('blocks.home.categories') }}</h2>
      <div class="az-section-head__divider"></div>
      {% if component.subtitle %}
        <p class="az-section-head__sub">{{ component.subtitle }}</p>
      {% endif %}
    </div>

    {# شبكة التصنيفات — من لوحة التحكم أو من المتجر #}
    <div class="az-cat-grid">
      {% set cats = component.categories is defined and component.categories|length > 0 ? component.categories : [] %}
      {% if cats|length > 0 %}
        {% for cat in cats %}
          <a href="{{ cat.url }}" class="az-cat-card">
            {% if cat.image is defined and cat.image %}
              <img src="{{ cat.image.url | default(cat.image) }}" alt="{{ cat.name }}" class="az-cat-card__img" loading="lazy">
            {% else %}
              <div class="az-cat-card__placeholder">
                <i class="sicon-layout-grid-rearrange"></i>
              </div>
            {% endif %}
            <div class="az-cat-card__overlay">
              <h3 class="az-cat-card__name">{{ cat.name }}</h3>
              <span class="az-cat-card__arrow">
                {{ trans('common.shop_now') }} <i class="sicon-arrow-left"></i>
              </span>
            </div>
          </a>
        {% endfor %}
      {% else %}
        {# حالة فارغة — placeholder #}
        {% for i in 1..4 %}
          <div class="az-cat-card">
            <div class="az-cat-card__placeholder">
              <i class="sicon-layout-grid-rearrange"></i>
            </div>
            <div class="az-cat-card__overlay">
              <h3 class="az-cat-card__name">{{ trans('common.category') }} {{ i }}</h3>
              <span class="az-cat-card__arrow">{{ trans('common.shop_now') }} <i class="sicon-arrow-left"></i></span>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>

    {% if component.show_view_all is not defined or component.show_view_all %}
    <div class="az-view-all-wrap">
      <a href="{{ link('categories') }}" class="az-btn-outline">
        <i class="sicon-layout-grid-rearrange"></i>
        {{ trans('blocks.home.display_all') }}
      </a>
    </div>
    {% endif %}
  </div>

</section>
