{# Top Bar Component - الشريط العلوي #}
<div class="w-full py-2 px-4 md:px-10 lg:px-40 flex justify-between items-center text-xs font-medium text-slate-400 border-b" style="background-color: #1e1a18; border-color: rgba(255, 255, 255, 0.05);">
    <div class="flex items-center gap-6">
        <div class="flex items-center gap-2 cursor-pointer hover:text-white transition-colors">
            <span class="material-symbols-outlined text-sm">public</span>
            <span>{{ 'اللغة' | trans }}: {{ store.language_label ?? 'العربية' }}</span>
        </div>
        <a href="{{ store.urls.track_order ?? '#' }}" class="flex items-center gap-2 hover:text-white transition-colors">
            <span class="material-symbols-outlined text-sm">local_shipping</span>
            <span>{{ 'تتبع طلبك' | trans }}</span>
        </a>
    </div>
    <div class="hidden md:flex items-center gap-4">
        <span style="color: var(--brand-secondary);">{{ 'خبرة أكثر من 10 سنوات' | trans }}</span>
        <span class="h-3 w-[1px]" style="background-color: rgba(255, 255, 255, 0.2);"></span>
        <span>{{ 'معدات احترافية موثوقة' | trans }}</span>
    </div>
</div>
