<header class="sticky top-0 z-50 bg-brand-dark text-white px-4 md:px-10 lg:px-40 py-4 shadow-xl" style="background-color: var(--brand-dark);">
    <div class="max-w-[1440px] mx-auto flex items-center justify-between gap-8">
        <!-- Logo -->
        <div class="flex items-center gap-3 order-last lg:order-none">
            <div class="size-10" style="color: var(--brand-secondary);">
                <svg fill="none" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                    <path clip-rule="evenodd" d="M24 0.757355L47.2426 24L24 47.2426L0.757355 24L24 0.757355ZM21 35.7574V12.2426L9.24264 24L21 35.7574Z" fill="currentColor" fill-rule="evenodd"></path>
                </svg>
            </div>
            <div class="flex flex-col">
                <h1 class="text-xl font-black leading-none tracking-tight">{{ store.name }}</h1>
                <span class="text-[10px] uppercase tracking-[0.2em]" style="color: var(--brand-secondary);">الهوية الأصلية</span>
            </div>
        </div>
        
        <!-- Search Bar -->
        <div class="flex-1 max-w-2xl hidden lg:block">
            <div class="relative">
                <div class="absolute inset-y-0 right-0 pr-4 flex items-center pointer-events-none text-slate-400">
                    <span class="material-symbols-outlined">search</span>
                </div>
                <input class="w-full bg-white/10 border-white/10 rounded-lg py-2.5 pr-12 pl-4 text-sm focus:ring-1 focus:border-brand-secondary transition-all placeholder:text-slate-400 text-white" 
                       placeholder="ابحث عن معدات الصيد والرحلات..." 
                       type="text"/>
            </div>
        </div>
        
        <!-- Right Menu -->
        <div class="flex items-center gap-2 md:gap-5 order-first lg:order-none">
            <button class="p-2.5 bg-white/5 rounded-lg text-white md:hidden">
                <span class="material-symbols-outlined">menu</span>
            </button>
            <div class="hidden md:flex flex-col items-start ml-2">
                <span class="text-[10px] text-slate-400">مرحباً بك</span>
                <span class="text-sm font-bold">تسجيل الدخول</span>
            </div>
            <button class="relative p-2.5 rounded-lg text-white hover:brightness-110 transition-all" style="background-color: var(--brand-secondary);">
                <span class="material-symbols-outlined">shopping_cart</span>
                <span class="absolute -top-1 -left-1 bg-white text-brand-dark text-[10px] font-bold h-5 w-5 rounded-full flex items-center justify-center border-2" style="border-color: var(--brand-dark);">{{ cart.items_count | default(0) }}</span>
            </button>
        </div>
    </div>
</header>
