{#
| Variable         | Type    | Description                     |
|------------------|---------|---------------------------------|
| cart             | object  |                                 |
| cart.items_count | int     |                                 |
| cart.total       | string  | Formatted total ex: "١٠٠ ر.س"   |
#}
{% set important_links = theme.settings.get('important_links') %}
<header class="store-header">
  {# الشريط العلوي - بني غامق #}
  <div class="top-navbar" style="background-color: #2F2824; color: rgba(255,255,255,0.85);">
    <div class="container flex justify-between items-center">
      <div class="flex-1 flex items-center gap-2">
          {# Footer Menu #}
          {% if important_links %}
            <salla-menu source="footer" topnav style="--salla-menu-color: rgba(255,255,255,0.75); --salla-menu-hover-color: #e8c88a;"></salla-menu>
          {% endif %}

          {# Language & Currency Component #}
          <div class="header-buttons">
              {% if store.settings.is_multilingual or store.settings.currencies_enabled %}
                  <button type="button" onclick="salla.event.dispatch('localization::open')" 
                          class="btn--rounded-gray basis-0"
                          style="background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.85); border: 1px solid rgba(255,255,255,0.15);">
                      <span>{{ user.language.name }}</span>
                      <span class="mx-1.5">|</span> <span>{{ currency.symbol }}</span>
                  </button>
                  <salla-localization-modal></salla-localization-modal>
              {% endif %}
          </div>

          {# Scopes | Branches #}
          {% if store.scope %}
              <button class="btn--rounded-gray"
                      style="background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.85);"
                      onclick="salla.event.dispatch('scopes::open', {'mode': 'default'})">
                  <i class="sicon-location rtl:ml-1 ltr:mr-1"></i> {{ store.scope.name }}
              </button>
          {% endif %}

          {# Search bar #}
          <div class="header-search flex-1">
            <salla-search inline oval height="36"></salla-search>
          </div>
      </div>

      <salla-contacts is-header style="--salla-contacts-color: rgba(255,255,255,0.75); --salla-contacts-hover-color: #e8c88a;"></salla-contacts>
    </div>
  </div>

  {# الشريط الرئيسي للتنقل - ذهبي/بني #}
  <div id="mainnav" class="main-nav-container shadow-default flex items-center" 
       style="background-color: #87602C;">
      <div class="inner w-full" style="background-color: inherit;">
          <div class="container">
              <div class="flex items-stretch justify-between relative">
                  <div class="flex items-center">
                      {# زر القائمة للموبايل #}
                      <a class="lg:hidden mburger mburger--collapse leading-none rtl:ml-4 ltr:mr-4" 
                         href="#mobile-menu" aria-label="Open-menu"
                         style="color: #fff;">
                        <i class="sicon-menu text-2xl" style="color: #fff;"></i>
                      </a>
                      
                      {# شعار المتجر #}
                      <a class="navbar-brand" href="{{ store.url }}">
                          <img fetchpriority="high" 
                               width="100%" height="100%" 
                               loading="eager" 
                               src="{{ store.logo|cdn(175) }}" 
                               alt="{{ store.name }} logo"
                               style="filter: brightness(0) invert(1); max-height: 48px; object-fit: contain;">
                          {% if is_page('index') %}
                            <h1 class="sr-only">{{ store.name }}</h1>
                          {% else %}
                            <h2 class="sr-only">{{ store.name }}</h2>
                          {% endif %}
                      </a>
                      
                      {# القائمة الرئيسية #}
                      <custom-main-menu style="--salla-menu-color: rgba(255,255,255,0.9); --salla-menu-hover-color: #fff; --salla-menu-active-color: #fff;"></custom-main-menu>
                  </div>
                  
                  {# أزرار الهيدر اليمين #}
                  <div class="flex items-center justify-end my-2.5 gap-1">
                      {# زر البحث للموبايل #}
                      <button class="header-btn lg:hidden" aria-label="search" 
                              onclick="salla.event.dispatch('search::open')"
                              style="color: #fff;">
                        <i class="header-btn__icon sicon-search" style="color: #fff;"></i>
                      </button>
                      
                      {# زر المستخدم #}
                      {% if user.type=='user' %}
                        <salla-user-menu avatar-only show-header 
                                         style="--salla-user-menu-color: #fff;"></salla-user-menu>
                      {% else %}
                          <button class="header-btn" aria-label="user-icon" 
                                  onclick="salla.event.dispatch('login::open')"
                                  style="color: #fff;">
                            <i class="header-btn__icon sicon-user-circle" style="color: #fff;"></i>
                          </button>
                      {% endif %}
                      
                      {# سلة التسوق #}
                      <salla-cart-summary class="rtl:mr-2 ltr:ml-2" style="--salla-cart-summary-color: #fff; --salla-cart-summary-badge-bg: #2F2824;">
                        <i slot="icon" class="header-btn__icon icon sicon-shopping-bag" style="color: #fff;"></i>
                      </salla-cart-summary>
                  </div>
              </div>
          </div>
      </div>
  </div>
</header>
