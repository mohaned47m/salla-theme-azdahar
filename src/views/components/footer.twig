<footer class="bg-brand-dark text-white" style="background-color: var(--brand-dark);">
    <div class="px-4 md:px-10 lg:px-40 py-16">
        <div class="max-w-[1440px] mx-auto grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
            <!-- About -->
            <div>
                <div class="flex items-center gap-2 mb-6">
                    <div class="size-8" style="color: var(--brand-secondary);">
                        <svg fill="none" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                            <path clip-rule="evenodd" d="M24 0.757355L47.2426 24L24 47.2426L0.757355 24L24 0.757355ZM21 35.7574V12.2426L9.24264 24L21 35.7574Z" fill="currentColor" fill-rule="evenodd"></path>
                        </svg>
                    </div>
                    <h3 class="text-lg font-black">{{ store.name }}</h3>
                </div>
                <p class="text-slate-400 text-sm leading-relaxed">{{ store.description }}</p>
            </div>
            
            <!-- Links -->
            <div>
                <h4 class="font-black mb-4" style="color: var(--brand-secondary);">الروابط السريعة</h4>
                <ul class="space-y-2 text-sm text-slate-400">
                    <li><a href="#" class="hover:text-white transition-colors">عن المتجر</a></li>
                    <li><a href="#" class="hover:text-white transition-colors">المنتجات</a></li>
                    <li><a href="#" class="hover:text-white transition-colors">العروض</a></li>
                    <li><a href="#" class="hover:text-white transition-colors">الاتصال بنا</a></li>
                </ul>
            </div>
            
            <!-- Support -->
            <div>
                <h4 class="font-black mb-4" style="color: var(--brand-secondary);">الدعم</h4>
                <ul class="space-y-2 text-sm text-slate-400">
                    <li><a href="#" class="hover:text-white transition-colors">سياسة الخصوصية</a></li>
                    <li><a href="#" class="hover:text-white transition-colors">شروط الاستخدام</a></li>
                    <li><a href="#" class="hover:text-white transition-colors">سياسة الإرجاع</a></li>
                    <li><a href="#" class="hover:text-white transition-colors">الأسئلة الشائعة</a></li>
                </ul>
            </div>
            
            <!-- Contact -->
            <div>
                <h4 class="font-black mb-4" style="color: var(--brand-secondary);">تواصل معنا</h4>
                <ul class="space-y-3 text-sm text-slate-400">
                    <li class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm">phone</span>
                        <span>{{ store.phone | default('+966 50 000 0000') }}</span>
                    </li>
                    <li class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm">mail</span>
                        <span>{{ store.email | default('info@salla.sa') }}</span>
                    </li>
                </ul>
            </div>
        </div>
        
        <!-- Bottom -->
        <div class="border-t" style="border-color: rgba(255, 255, 255, 0.1);">
            <div class="pt-8 flex flex-col md:flex-row justify-between items-center text-xs text-slate-400">
                <p>&copy; 2026 {{ store.name }}. جميع الحقوق محفوظة.</p>
                <div class="flex gap-4 mt-4 md:mt-0">
                    <a href="#" class="hover:text-white transition-colors">Facebook</a>
                    <a href="#" class="hover:text-white transition-colors">Instagram</a>
                    <a href="#" class="hover:text-white transition-colors">Twitter</a>
                </div>
            </div>
        </div>
    </div>
</footer>
