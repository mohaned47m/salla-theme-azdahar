        {
            "type": "boolean",
            "icon": "sicon-toggle-off",
            "label": "الشريط العلوي الداكن",
            "description": "تفعيل الشريط العلوي بخلفية داكنة",
            "id": "topnav_is_dark",
            "format": "switch",
            "required": false,
            "value": false,
            "selected": false
        },
        {
            "type": "string",
            "id": "placeholder",
            "format": "hidden",
            "value": "images/img_placeholder.png"
        }
    ]
